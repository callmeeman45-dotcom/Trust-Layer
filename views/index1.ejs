<script>
  function selectProduct(n) {
    document.getElementById('p1').classList.remove('active');
    document.getElementById('p2').classList.remove('active');
    document.getElementById('p' + n).classList.add('active');
    const badge = document.getElementById('scanBadge');
    const status = document.getElementById('scanStatus');
    if (n === 1) {
      status.textContent = 'First scan · Authentic';
      badge.textContent = '✔ Verified';
      badge.style.color = 'var(--sage)';
      badge.style.borderColor = 'var(--sage)';
    } else {
      status.textContent = 'Duplicate scan · Alert';
      badge.textContent = '⚠ Check product';
      badge.style.color = '#C8821A';
      badge.style.borderColor = '#C8821A';
    }
  }

  function toggleMenu() {
    document.getElementById('mobileMenu').classList.toggle('open');
  }
  document.addEventListener('click', function(e) {
    const menu = document.getElementById('mobileMenu');
    const hamburger = document.getElementById('hamburger');
    if (!menu.contains(e.target) && !hamburger.contains(e.target)) {
      menu.classList.remove('open');
    }
  });
</script>
