
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans,system-ui,sans-serif)}
.wrap{background:#0a0f0a;color:#e8f5e8;min-height:100vh;display:flex}
.sidebar{width:220px;background:#060c06;border-right:1px solid #1a3a1a;display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh}
.sb-logo{padding:24px 20px 20px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #1a3a1a}
.sb-logo-icon{width:30px;height:30px;background:#1a4d1a;border:1px solid #2d7a2d;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-logo span{font-size:14px;font-weight:500;color:#a8e6a8;letter-spacing:0.03em}
.sb-user{padding:16px 20px;border-bottom:1px solid #1a3a1a}
.sb-avatar{width:36px;height:36px;background:#1a4d1a;border:1px solid #2d7a2d;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;color:#4caf50;margin-bottom:8px}
.sb-uname{font-size:13px;font-weight:500;color:#a8e6a8}
.sb-uemail{font-size:10px;color:#3a6b3a;letter-spacing:0.05em;margin-top:2px}
.sb-plan{display:inline-flex;align-items:center;gap:5px;background:#0d2a0d;border:1px solid #2d7a2d;padding:3px 9px;border-radius:100px;margin-top:8px}
.sb-plan span{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#4caf50}
.sb-nav{padding:12px 0;flex:1}
.sb-nav-label{font-size:8px;letter-spacing:0.35em;text-transform:uppercase;color:#1a4d1a;padding:10px 20px 6px}
.sb-link{display:flex;align-items:center;gap:10px;padding:10px 20px;font-size:12px;color:#3a6b3a;cursor:pointer;transition:all 0.15s;border-left:2px solid transparent;letter-spacing:0.05em}
.sb-link:hover{color:#a8e6a8;background:#0d1a0d;border-left-color:#2d7a2d}
.sb-link.active{color:#4caf50;background:#0d1f0d;border-left-color:#4caf50}
.sb-link svg{flex-shrink:0}
.sb-bottom{padding:16px 20px;border-top:1px solid #1a3a1a}
.main{flex:1;display:flex;flex-direction:column;overflow:auto}
.topbar{background:#060c06;border-bottom:1px solid #1a3a1a;padding:0 32px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
.topbar-left{display:flex;align-items:center;gap:8px}
.topbar-page{font-size:16px;font-weight:500;color:#e8f5e8}
.topbar-sep{color:#1a4d1a;font-size:12px}
.topbar-sub{font-size:12px;color:#3a6b3a;letter-spacing:0.1em}
.topbar-right{display:flex;align-items:center;gap:12px}
.tb-search{background:#0d1a0d;border:1px solid #1a3a1a;border-radius:6px;padding:7px 14px;font-size:12px;color:#5a8c5a;display:flex;align-items:center;gap:8px;cursor:text;letter-spacing:0.05em}
.tb-notif{width:32px;height:32px;background:#0d1a0d;border:1px solid #1a3a1a;border-radius:6px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.content{padding:32px;flex:1}
.quick-actions{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:28px}
.qa-card{background:#0d1a0d;border:1px solid #1a3a1a;border-radius:10px;padding:20px 18px;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden}
.qa-card:hover{border-color:#2d7a2d;background:#0f1f0f}
.qa-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#2d7a2d,transparent);opacity:0;transition:opacity 0.2s}
.qa-card:hover::before{opacity:1}
.qa-icon{width:38px;height:38px;background:#1a3a1a;border-radius:8px;display:flex;align-items:center;justify-content:center;margin-bottom:14px}
.qa-title{font-size:13px;font-weight:500;color:#a8e6a8;margin-bottom:4px}
.qa-desc{font-size:10px;color:#3a6b3a;line-height:1.5;letter-spacing:0.03em}
.qa-arrow{position:absolute;top:18px;right:18px;color:#2d7a2d;font-size:14px}
.section-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.section-row.full{grid-template-columns:1fr}
.panel{background:#0d1a0d;border:1px solid #1a3a1a;border-radius:10px;padding:22px}
.panel-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.panel-title{font-size:13px;font-weight:500;color:#a8e6a8}
.panel-action{font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:#2d7a2d;cursor:pointer;background:#0d2a0d;border:1px solid #1a4d1a;padding:5px 12px;border-radius:4px}
.panel-action:hover{border-color:#2d7a2d;color:#4caf50}
.stats-mini{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px}
.sm-card{background:#111811;border:1px solid #1a3a1a;border-radius:8px;padding:14px 12px;text-align:center}
.sm-num{font-size:22px;font-weight:500;color:#4caf50;letter-spacing:-0.02em;display:block}
.sm-lbl{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#3a6b3a;margin-top:3px}
.product-row{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #1a3a1a}
.product-row:last-child{border-bottom:none}
.pr-icon{width:32px;height:32px;background:#1a3a1a;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pr-info{flex:1}
.pr-name{font-size:12px;font-weight:500;color:#a8e6a8}
.pr-id{font-size:10px;color:#3a6b3a;font-family:var(--font-mono,monospace);letter-spacing:0.05em;margin-top:1px}
.pr-badge{font-size:9px;padding:3px 9px;border-radius:100px;letter-spacing:0.1em;border:1px solid}
.pr-badge.active{background:#0d2a0d;border-color:#2d7a2d;color:#4caf50}
.pr-badge.warn{background:#1a1200;border-color:#5a3c00;color:#d4a017}
.pr-scans{font-size:11px;color:#3a6b3a;text-align:right;margin-left:auto}
.pr-scans strong{display:block;font-size:13px;color:#a8e6a8;font-weight:500;text-align:right}
.activity-row{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid #1a3a1a}
.activity-row:last-child{border-bottom:none}
.act-dot{width:8px;height:8px;border-radius:50%;margin-top:4px;flex-shrink:0}
.act-dot.green{background:#4caf50}
.act-dot.amber{background:#d4a017}
.act-dot.blue{background:#378add}
.act-info{flex:1}
.act-msg{font-size:12px;color:#a8e6a8;line-height:1.5}
.act-time{font-size:10px;color:#3a6b3a;margin-top:2px;letter-spacing:0.05em}
.scan-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.scan-bar-label{font-size:11px;color:#5a8c5a;width:110px;flex-shrink:0}
.scan-bar-track{flex:1;background:#1a3a1a;border-radius:4px;height:6px;overflow:hidden}
.scan-bar-fill{height:100%;background:#2d7a2d;border-radius:4px;transition:width 0.4s}
.scan-bar-val{font-size:11px;color:#3a6b3a;width:40px;text-align:right;flex-shrink:0}
.empty-state{text-align:center;padding:40px 20px}
.empty-icon{width:48px;height:48px;background:#1a3a1a;border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
.empty-text{font-size:13px;color:#3a6b3a;margin-bottom:12px}
.add-btn{display:inline-flex;align-items:center;gap:6px;background:#2d7a2d;color:#e8f5e8;border:none;padding:8px 18px;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;cursor:pointer;border-radius:4px;font-family:inherit}
.add-btn:hover{background:#3a9e3a}
.logout-btn{display:flex;align-items:center;gap:8px;width:100%;padding:9px 12px;background:transparent;border:1px solid #1a3a1a;border-radius:6px;color:#3a6b3a;font-size:11px;letter-spacing:0.1em;cursor:pointer;font-family:inherit;transition:all 0.2s}
.logout-btn:hover{border-color:#2d4a2d;color:#5a8c5a}
</style>

<div class="wrap">
  <aside class="sidebar">
    <div class="sb-logo">
      <div class="sb-logo-icon">
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none"><path d="M9 2L3 6v4c0 3.3 2.5 6.4 6 7.2C12.5 16.4 15 13.3 15 10V6L9 2z" fill="#4caf50" opacity="0.9"/><path d="M7 9.5l1.5 1.5 3-3" stroke="#0d1a0d" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <span>Trust Layer</span>
    </div>
    <div class="sb-user">
      <div class="sb-avatar">AR</div>
      <div class="sb-uname"><%= username %></div>
      <div class="sb-uemail"><%= email %></div>
      <div class="sb-plan"><div style="width:5px;height:5px;border-radius:50%;background:#4caf50"></div><span>Pro plan</span></div>
    </div>
    <nav class="sb-nav">
