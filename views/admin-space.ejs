        Analytics
      </div>
      <div class="sb-nav-label" style="margin-top:8px">Tools</div>
      <div class="sb-link" onclick="setActive(this)">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5" stroke="#3a6b3a" stroke-width="1.2"/><circle cx="8" cy="8" r="2" stroke="#3a6b3a" stroke-width="1.2"/><path d="M8 1v2M8 13v2M1 8h2M13 8h2" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round"/></svg>
        Scan Monitor
      </div>
      <div class="sb-link" onclick="setActive(this)">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="10" rx="1.5" stroke="#3a6b3a" stroke-width="1.2"/><path d="M5 7h6M5 10h4" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round"/></svg>
        Lab Reports
      </div>
      <div class="sb-link" onclick="setActive(this)">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5" r="3" stroke="#3a6b3a" stroke-width="1.2"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round"/></svg>
        Account Settings
      </div>
    </nav>
    <form action="/logout" method="POST">
    <div class="sb-bottom">
      <button class="logout-btn" type="submit">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M11 5l3 3-3 3M14 8H7" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Sign out
      </button>
    </div>
    </form>
