          <div class="qa-icon">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="2" stroke="#4caf50" stroke-width="1.2"/><path d="M10 7v6M7 10h6" stroke="#4caf50" stroke-width="1.2" stroke-linecap="round"/></svg>
          </div>
