<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Products — Trust Layer</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: white;
      color: #e8f5e8;
      min-height: 100vh;
    }

    /* NAV */
    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 40px;
      height: 64px;
      /* background: #6e5830; */
  background-image: linear-gradient(135deg, #302511, #362a12);

      border-bottom: 1px solid white;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }
    .nav-icon {
      width: 32px;
      height: 32px;
      background: #221b0d;
      border: 1px solid #6e5830;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .nav-title {
      font-size: 15px;
      font-weight: 500;
      color: white;
      letter-spacing: 0.03em;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .nav-link {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: white;
      text-decoration: none;
      padding: 7px 14px;
      border-radius: 6px;
      transition: all 0.2s;
    }
    .nav-link:hover { color: #a8e6a8; background: #0d1a0d; }
    .nav-link.active { color: white; background: #0d1f0d; }
    .nav-btn {
      background: white;
      color: #6e5830;
      border: none;
      padding: 8px 18px;
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      border-radius: 6px;
      font-family: inherit;
      transition: background 0.2s;
      text-decoration: none;
    }
   
    .nav-btn:hover { background: #2e2412; }

    /* PAGE HEADER */
    .page-header {
      padding: 40px 40px 28px;
      border-bottom: 1px solid #1a3a1a;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .page-tag {
      font-size: 9px;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: #6e5830;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .page-tag::after {
      content: '';
      flex: 0 0 32px;
      height: 1px;
      background: #1a3a1a;
    }
    .page-title {
      font-size: 26px;
      font-weight: 500;
      color:#6e5830;
      letter-spacing: -0.02em;
    }
    .page-count {
      font-size: 13px;
      color: white;
      margin-top: 4px;
    }
    .add-btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: #6e5830;
      color: #e8f5e8;
      border: none;
      padding: 11px 22px;
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      border-radius: 7px;
      font-family: inherit;
      transition: background 0.2s;
      text-decoration: none;
    }
    .add-btn:hover { background: #221a0c; }

    /* GRID */
    .products-wrap { padding: 36px 40px; }
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
     
    }

    /* PRODUCT CARD */
    .product-card {
      background: white;
      border: 1px solid #6e5830;
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 0.25s, background 0.25s;
      position: relative;
    }
   
    .product-card:hover { border-color: #6e5830; background:#20190c; }
    .product-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, #6e5830, transparent);
      opacity: 0;
      transition: opacity 0.25s;
    }
    .product-card:hover::before { opacity: 1; }

    .card-img-wrap {
      width: 100%;
      height: 200px;
      background: #6e5830;
      border-bottom: 1px solid #1a3a1a;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .card-img-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }
    .card-img-placeholder span {
      font-size: 10px;
      color: #6e5830;
      letter-spacing: 0.1em;
    }

    .card-body { padding: 20px; }

    .card-batch {
      font-size: 9px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: #6e5830;
      font-family: monospace;
      margin-bottom: 8px;
    }
    .card-name {
      font-size: 16px;
      font-weight: 500;
      color: #e8f5e8;
      margin-bottom: 6px;
      line-height: 1.3;
    }
    .card-desc {
      font-size: 12px;
      color: white;
      line-height: 1.7;
      margin-bottom: 16px;
      display: -webkit-box;
      /* -webkit-line-clamp: 2; */
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 16px;
    }
    .meta-item {
      background: #6e5830;
      border: 1px solid #6e5830;
      border-radius: 7px;
      padding: 10px 12px;
    }
    .meta-label {
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: white;
      margin-bottom: 3px;
    }
    .meta-value {
      font-size: 13px;
      color: white;
      font-weight: 500;
    }
    .meta-value.green { color: white; }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 14px;
      border-top: 1px solid #6e5830;
    }
    .count-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      background: #6e5830;
      border: 1px solid #6e5830;
      border-radius: 100px;
      padding: 5px 12px;
    }
    .count-dot { width: 5px; height: 5px; border-radius: 50%; background: white; }
    .count-text { font-size: 11px; color: white; letter-spacing: 0.1em; }
.form{
  display: inline-block;
}
    .view-btn {
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #6e5830;
      cursor: pointer;
      background: none;
      border: 1px solid white;
      padding: 6px 14px;
      border-radius: 5px;
      font-family: inherit;
      transition: all 0.2s;
      text-decoration: none;
    }
    .view-btn:hover { border-color: #6e5830; color: white; background: #6e5830; }

    /* EMPTY STATE */
    .empty { text-align: center; padding: 80px 20px; }
    .empty-icon {
      width: 64px;
      height: 64px;
      background: #0d1a0d;
      border: 1px solid #1a3a1a;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }
    .empty-title { font-size: 18px; font-weight: 500; color: #e8f5e8; margin-bottom: 8px; }
    .empty-sub { font-size: 13px; color: white; margin-bottom: 24px; line-height: 1.7; }

    /* FOOTER */
    .footer {
      /* background: #6e5830; */
  background-image: linear-gradient(135deg, #302511, #362a12);

      border-top: 1px solid white;
      padding: 28px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 20px;
    }
    .footer-brand { font-size: 13px; color: white; }
    .footer-brand strong { color: white; }
    .footer-copy { font-size: 10px; letter-spacing: 0.12em; color: white; }
    /* .flex{
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    } */
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <a class="nav-brand" href="/">
      <div class="nav-icon">
        <svg width="17" height="17" viewBox="0 0 18 18" fill="none">
          <path d="M9 2L3 6v4c0 3.3 2.5 6.4 6 7.2C12.5 16.4 15 13.3 15 10V6L9 2z" fill="white" opacity="0.9"/>
          <path d="M7 9.5l1.5 1.5 3-3" stroke="#0d1a0d" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="nav-title">Trust Layer</span>
    </a>
    <div class="nav-links">
      <a class="nav-link" href="/admin/space">Dashboard</a>
      <a class="nav-link active" href="/all-products">All Products</a>
      <a class="nav-link" href="/analytics">Analytics</a>
      <a class="nav-btn" href="/add-product">+ Add Product</a>
    </div>
  </nav>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div>
      <div class="page-tag">Product registry</div>
      <div class="page-title">All products</div>
      <div class="page-count"><%= products.length %> batch<%= products.length !== 1 ? 'es' : '' %> registered</div>
    </div>
    <a class="add-btn" href="/add-product">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <path d="M8 2v12M2 8h12" stroke="#e8f5e8" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Add new product
    </a>
  </div>

  <!-- PRODUCTS -->
  <div class="products-wrap">

    <% if (products.length === 0) { %>
      <div class="empty">
        <div class="empty-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect x="4" y="4" width="20" height="20" rx="3" stroke="#6e5830" stroke-width="1.4"/>
            <path d="M14 10v8M10 14h8" stroke="#6e5830" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="empty-title">No products yet</div>
        <div class="empty-sub">You haven't registered any products.<br>Add your first product to start generating QR codes.</div>
        <a class="add-btn" href="/add-product">Add your first product ↗</a>
      </div>

    <% } else { %>
      <div  class="flex">
        <div class="products-grid">
      <% for (let product of products) { %>
          <form  class="form"  action="/admin/batch/<%=product._id %>/download-pdf" method="get">
          <div class="product-card">

            <div class="card-img-wrap">
              <% if (product.image) { %>
                <img src="<%= product.image %>" alt="Product image">
              <% } else { %>
                <div class="card-img-placeholder">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                    <rect x="4" y="4" width="28" height="28" rx="4" stroke="#1a4d1a" stroke-width="1.4"/>
                    <circle cx="13" cy="14" r="3" stroke="#1a4d1a" stroke-width="1.4"/>
                    <path d="M4 26l8-6 5 4 5-5 10 7" stroke="#1a4d1a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>No image</span>
                </div>
                <% } %>
              </div>

            <div class="card-body">
              <div class="card-batch">Batch · <%= product._id %></div>
               
              <div class="card-name"><%= product._id %></div>
              <div class="card-desc"><%= product.description || 'No description provided.' %></div>
             

              <div class="card-meta">
                <div class="meta-item">
                  <div class="meta-label">Price</div>
                  <div class="meta-value green"><%= product.price %></div>
                </div>
                <div class="meta-item">
                  <div class="meta-label">Units in batch</div>
                  <div class="meta-value"><%= product.count %></div>
                </div>
              </div>

              <div class="card-footer">
                <div class="count-badge">
                  <div class="count-dot"></div>
                  <span class="count-text"><%= product.count %> unit<%= product.count !== 1 ? 's' : '' %></span>
                </div>
               
                <button class="view-btn" type="submit">Download Pdf↗</button>
                 <a href="/batch/edit/<%=product._id %>"><button class="view-btn">Edit</button></a>
              </div>
            </div>

          </form>
          </div>
        <% } %>
    </div>
    <% } %>
  </div>

  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-brand"><strong>Trust Layer</strong> · Anti-Counterfeit Platform</div>
    <div class="footer-copy">© 2026 Trust Layer · All Rights Reserved</div>
  </footer>

</body>
</html>
