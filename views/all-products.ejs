<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>All Products — Trust Layer</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Outfit:wght@200;300;400;500&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/dashboard-layout.css">
  <style>
    /* PAGE HEADER */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 16px;
    }

    .page-tag {
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 8px;
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      color: var(--ink);
      margin-bottom: 4px;
    }

    .page-count {
      font-size: 12px;
      color: var(--umber);
    }

    

    

    /* GRID */
    .products-wrap {
      /* padding: 36px 40px; */
    }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 24px;
    }

    /* PRODUCT CARD */
    .product-card {
      border-radius: 20px;
      background: var(--amber);
      padding: 5px;
      overflow: hidden;
      box-shadow: rgba(0, 0, 0, 0.2) 0px 7px 20px 0px;
      transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.25s;
      border: 1px solid rgba(255, 255, 255, 0.05);
      position: relative;
    }

    .product-card:hover {
      transform: scale(1.05);
      border-color: var(--honey);
      box-shadow: 0 10px 25px rgba(250, 87, 22, 0.2);
    }

    .product-card .top-section {
      height: 240px;
      border-radius: 15px;
      display: flex;
      flex-direction: column;
      background: #ffffff;
      position: relative;
      overflow: hidden;
    }

    .product-card .top-section img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 15px;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 1;
    }

    .product-card .top-section .border {
      border-bottom-right-radius: 10px;
      height: 30px;
      width: 130px;
      background: var(--amber);
      position: relative;
      transform: skew(-40deg);
      box-shadow: -10px -10px 0 0 var(--amber);
      z-index: 3;
    }

    .product-card .top-section .border::before {
      content: "";
      position: absolute;
      width: 15px;
      height: 15px;
      top: 0;
      right: -15px;
      background: rgba(255, 255, 255, 0);
      border-top-left-radius: 10px;
      box-shadow: -5px -5px 0 2px var(--amber);
    }

    .product-card .top-section::before {
      content: "";
      position: absolute;
      top: 30px;
      left: 0;
      background: rgba(255, 255, 255, 0);
      height: 15px;
      width: 15px;
      border-top-left-radius: 15px;
      box-shadow: -5px -5px 0 2px var(--amber);
      z-index: 3;
    }

    .product-card .top-section .icons {
      position: absolute;
      top: 0;
      width: 100%;
      height: 30px;
      display: flex;
      justify-content: space-between;
      z-index: 4;
    }

    .product-card .top-section .icons .logo {
      height: 100%;
      padding: 7px 0 7px 15px;
      font-size: 10px;
      color: rgba(255, 255, 255, 0.6);
      font-family: monospace;
      letter-spacing: 0.1em;
      white-space: nowrap;
      display: flex;
      align-items: center;
    }

    .product-card .top-section .icons .social-media {
      height: 100%;
      padding: 8px 15px;
      display: flex;
      gap: 7px;
    }

    .product-card .top-section .icons .social-media .svg {
      height: 100%;
      fill: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      transition: fill 0.2s;
    }

    .product-card .top-section .icons .social-media .svg:hover {
      fill: var(--honey);
    }

    .product-card .bottom-section {
      margin-top: 15px;
      padding: 10px 5px;
    }

    .product-card .bottom-section .title {
      display: block;
      font-size: 17px;
      font-weight: bolder;
      color: white;
      text-align: center;
      letter-spacing: 2px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .product-card .bottom-section .desc {
      display: block;
      font-size: 11px;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.5;
      text-align: center;
      margin-top: 6px;
      height: 33px;
      overflow: hidden;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }

    .product-card .bottom-section .row {
      display: flex;
      justify-content: space-between;
      margin-top: 20px;
    }

    .product-card .bottom-section .row .item {
      flex: 30%;
      text-align: center;
      padding: 5px;
      color: #fff;
    }

    .product-card .bottom-section .row .item .big-text {
      font-size: 12px;
      display: block;
      color: #fff;
    }

    .product-card .bottom-section .row .item .regular-text {
      font-size: 9px;
      color: rgba(255, 255, 255, 0.5);
    }

    .product-card .bottom-section .row .item:nth-child(2) {
      border-left: 1px solid rgba(255, 255, 255, 0.126);
      border-right: 1px solid rgba(255, 255, 255, 0.126);
    }

    .product-card .bottom-section .row .item button.download-icon-btn {
      background: none;
      border: none;
      color: var(--honey);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s, transform 0.2s;
      padding: 0;
    }

    .product-card .bottom-section .row .item button.download-icon-btn:hover {
      color: #fff;
      transform: scale(1.15);
    }

    /* EMPTY STATE */
    .empty {
      text-align: center;
      padding: 80px 20px;
    }

    .empty-icon {
      width: 64px;
      height: 64px;
      background: var(--parchment);
      border: 1px dashed var(--amber);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }

    .empty-title {
      font-size: 18px;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 8px;
    }

    .empty-sub {
      font-size: 13px;
      color: var(--umber);
      margin-bottom: 24px;
      line-height: 1.7;
    }

    .form {
      display: inline-block;
      width: 100%;
    }
  </style>
</head>

<body>

  <%- include('partials/sidebar', { active: 'all-products' }) %>

  <!-- MAIN -->
  <div class="main">

    <%- include('partials/topbar', { pageTitle: 'All Products', pageSub: 'Manage your product inventory' }) %>

    <!-- CONTENT -->
    <div class="content" style="padding: 36px 40px; overflow-y: auto;">
      
      <!-- PAGE HEADER -->
      <div class="page-header">
        <div>
          <div class="page-tag">Product registry</div>
          <div class="page-title">All products</div>
          <div class="page-count">
            <%= products.length %> batch<%= products.length !==1 ? 'es' : '' %> registered
          </div>
        </div>
        <a class="add-btn" href="/add-product">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span>Add new product</span>
        </a>
      </div>

      <!-- PRODUCTS -->
      <div class="products-wrap">

        <% if (products.length===0) { %>
          <div class="empty">
            <div class="empty-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <rect x="4" y="4" width="20" height="20" rx="3" stroke="var(--honey)" stroke-width="1.4" />
                <path d="M14 10v8M10 14h8" stroke="var(--honey)" stroke-width="1.4" stroke-linecap="round" />
              </svg>
            </div>
            <div class="empty-title">No products yet</div>
            <div class="empty-sub">You haven't registered any products.<br>Add your first product to start generating QR
              codes.</div>
            <a class="add-btn" href="/add-product"><span>Add your first product ↗</span></a>
          </div>

          <% } else { %>
            <div class="flex">
              <div class="products-grid">
                <% for (let product of products) { %>
                  <form class="form" action="/admin/batch/<%=product._id %>/download-pdf" method="get">
                    <div class="product-card">
                      <div class="top-section">
                        <div class="border"></div>
                        <div class="icons">
                          <div class="logo">
                            <%= product._id %>
                          </div>
                        </div>
                        <% if (product.image) { %>
                          <img src="<%= product.image %>" alt="Product image">
                        <% } %>
                      </div>
                      <div class="bottom-section">
                        <span class="title"><%= product.name || product._id %></span>
                        <span class="desc"><%= product.description || 'No description provided.' %></span>
                        <div class="row">
                          <div class="item">
                            <span class="big-text">$<%= product.price %></span>
                            <span class="regular-text">Price</span>
                          </div>
                          <div class="item">
                            <span class="big-text"><%= product.count %></span>
                            <span class="regular-text">Units</span>
                          </div>
                          <div class="item">
                            <button class="download-icon-btn" type="submit" title="Download PDF">
                              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="7 10 12 15 17 10"></polyline>
                                <line x1="12" y1="15" x2="12" y2="3"></line>
                              </svg>
                            </button>
                            <span class="regular-text">PDF</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </form>
              <% } %>
            </div>
            </div>
          <% } %>
      </div>

    </div>
  </div>

</body>
</html>