<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics Dashboard — Trust Layer</title>
  <link rel="stylesheet" href="/css/dashboard-layout.css">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

  <style>
    :root {
      --honey: #FA5716; /* Vibrant Orange */
      --amber: #0F5C5B; /* Deep Teal */
      --umber: #94A3B8; /* Muted Slate */
      --ink: #0F172A;
      --cream: #F8FAFC;
      --danger: #ef4444;
      --success: #10b981;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--cream);
      color: var(--ink);
      min-height: 100vh;
    }

    /* ── PAGE HEADER / TOP ROW ── */
    .dashboard-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 16px;
      flex-shrink: 0;
    }

    .page-tag {
      font-size: 10px;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--amber);
      font-weight: 500;
      margin-bottom: 8px;
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 600;
      color: var(--ink);
    }

    .page-sub {
      font-size: 13px;
      color: var(--umber);
      margin-top: 4px;
    }

    /* ── STATS CARDS ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 24px;
      width: 100%;
      flex-shrink: 0;
    }

    .stat-card {
      background: #ffffff;
      border: 1.5px solid rgba(15, 92, 91, 0.08);
      border-radius: 18px;
      padding: 24px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 30px rgba(15, 92, 91, 0.05);
    }

    .stat-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--kpi-color, var(--umber));
    }

    .stat-card .stat-num {
      font-size: 36px;
      font-weight: 700;
      color: var(--kpi-text-color, var(--ink));
      font-family: 'Playfair Display', serif;
      margin-bottom: 4px;
    }

    .stat-card .stat-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--umber);
      margin-bottom: 8px;
    }

    .stat-card .stat-sub {
      font-size: 13px;
      color: #64748B;
    }

    /* ── CHARTS GRID ── */
    .charts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin-bottom: 24px;
    }

    @media (max-width: 768px) {
      .charts-grid {
        grid-template-columns: 1fr;
      }
    }

    .chart-card {
      background: #ffffff;
      border: 1.5px solid rgba(15, 92, 91, 0.08);
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .chart-card.full-width {
      grid-column: 1 / -1;
    }

    .chart-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .chart-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .chart-title::before {
      content: '';
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--honey);
    }

    .chart-sub {
      font-size: 12px;
      color: var(--umber);
    }

    .chart-container {
      position: relative;
      flex-grow: 1;
      min-height: 300px;
      width: 100%;
      min-width: 0;
    }
  </style>
</head>

<body>

  <%- include('partials/sidebar', { active: 'analytics' }) %>

  <!-- MAIN DASHBOARD AREA -->
  <div class="main">

    <%- include('partials/topbar', { pageTitle: 'Analytics', pageSub: 'Deep dive into scan intelligence' }) %>

    <!-- CONTENT -->
    <div class="content" style="padding: 36px 40px; overflow-y: auto;">
      
      <!-- PAGE HEADER -->
      <div class="dashboard-header">
        <div>
          <div class="page-tag">Live Data</div>
          <div class="page-title"><%= brandname %> Analytics Dashboard</div>
          <div class="page-sub">Comprehensive insights across all your registered products and scan events.</div>
        </div>
      </div>

      <% 
        const genuineCount = statusCount.Genuine || 0;
        const counterfeitCount = statusCount.Counterfeit || 0;
        const total = genuineCount + counterfeitCount || 1; // Prevent division by zero
        
        const genuinePct = ((genuineCount / total) * 100).toFixed(1);
        const counterfeitPct = ((counterfeitCount / total) * 100).toFixed(1);
      %>

      <!-- STATS ROW -->
      <div class="stats-row">
        <!-- Total Scans -->
        <div class="stat-card" style="--kpi-color: var(--amber); --kpi-text-color: var(--amber);">
          <div class="stat-label">Total Scans</div>
          <div class="stat-num"><%= totalScans %></div>
          <div class="stat-sub">All QR scan events recorded</div>
        </div>

        <!-- Genuine -->
        <div class="stat-card" style="--kpi-color: var(--success); --kpi-text-color: var(--success);">
          <div class="stat-label">Genuine</div>
          <div class="stat-num"><%= genuineCount %></div>
          <div class="stat-sub"><%= totalScans === 0 ? '0' : genuinePct %>% of total</div>
        </div>

        <!-- Counterfeit -->
        <div class="stat-card" style="--kpi-color: var(--danger); --kpi-text-color: var(--danger);">
          <div class="stat-label">Counterfeit</div>
          <div class="stat-num"><%= counterfeitCount %></div>
          <div class="stat-sub"><%= totalScans === 0 ? '0' : counterfeitPct %>% of total</div>
        </div>

        <!-- Unique Products -->
        <div class="stat-card" style="--kpi-color: var(--honey); --kpi-text-color: var(--honey);">
          <div class="stat-label">Unique Products</div>
          <div class="stat-num"><%= productChart.labels.length %></div>
          <div class="stat-sub">Multi-scanned SKUs</div>
        </div>

        <!-- Countries -->
        <div class="stat-card" style="--kpi-color: #3b82f6; --kpi-text-color: #3b82f6;">
          <div class="stat-label">Countries</div>
          <div class="stat-num"><%= geoChart.labels.length %></div>
          <div class="stat-sub">Geographic regions</div>
        </div>
      </div>

      <!-- CHARTS -->
      <div class="charts-grid">
        
        <!-- Genuine vs Counterfeit -->
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Status Breakdown</div>
              <div class="chart-sub">Distribution across all scans</div>
            </div>
          </div>
          <div class="chart-container" style="display:flex; justify-content:center; align-items:center; min-height: 250px;">
            <canvas id="statusChart" style="max-height: 250px;"></canvas>
          </div>
        </div>

        <!-- Top Products -->
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Top Scanned Products</div>
              <div class="chart-sub">Scan volume by product ID</div>
            </div>
          </div>
          <div class="chart-container">
            <canvas id="productChart"></canvas>
          </div>
        </div>

        <!-- Device Analytics -->
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Device Fingerprints</div>
              <div class="chart-sub">Scans grouped by unique device characteristics</div>
            </div>
          </div>
          <div class="chart-container">
            <canvas id="deviceChart"></canvas>
          </div>
        </div>

        <!-- Geographic Distribution -->
        <div class="chart-card">
          <div class="chart-header">
            <div>
              <div class="chart-title">Geographic Activity</div>
              <div class="chart-sub">Scans distributed by country</div>
            </div>
          </div>
          <div class="chart-container">
            <canvas id="geoChart"></canvas>
          </div>
        </div>

        <!-- Scans Over Time -->
        <div class="chart-card full-width">
          <div class="chart-header">
            <div>
              <div class="chart-title">Scans Over Time</div>
              <div class="chart-sub">Daily scan activity by status</div>
            </div>
          </div>
          <div class="chart-container">
            <canvas id="timeChart"></canvas>
          </div>
        </div>

      </div>

    </div>
  </div>

  <script>
    // Injected Data from Backend
    const stCount = <%- JSON.stringify(statusCount) %>;
    const scansOverTime = <%- JSON.stringify(scansOverTime) %>;
    const deviceData = <%- JSON.stringify(deviceChart) %>;
    const prodData = <%- JSON.stringify(productChart) %>;
    const geoData = <%- JSON.stringify(geoChart) %>;

    // Common Chart Options
    Chart.defaults.font.family = "'Outfit', sans-serif";
    Chart.defaults.color = '#94A3B8';
    
    const tooltipSettings = {
      backgroundColor: '#1E293B',
      titleColor: '#F8FAFC',
      bodyColor: '#CBD5E1',
      borderColor: 'rgba(255,255,255,0.1)',
      borderWidth: 1,
      padding: 12,
      cornerRadius: 8,
      displayColors: true
    };

    // 1. Status Chart (Doughnut)
    new Chart(document.getElementById('statusChart'), {
      type: 'doughnut',
      data: {
        labels: ['Genuine', 'Counterfeit'],
        datasets: [{
          data: [stCount.Genuine || 0, stCount.Counterfeit || 0],
          backgroundColor: ['#0F5C5B', '#FA5716'],
          borderWidth: 0,
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '75%',
        plugins: {
          legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, pointStyle: 'circle' } },
          tooltip: tooltipSettings
        }
      }
    });

    // 2. Scans Over Time (Line)
    new Chart(document.getElementById('timeChart'), {
      type: 'line',
      data: {
        labels: scansOverTime.labels,
        datasets: [
          {
            label: 'Genuine',
            data: scansOverTime.genuine,
            borderColor: '#0F5C5B',
            backgroundColor: 'rgba(15, 92, 91, 0.1)',
            borderWidth: 2,
            pointBackgroundColor: '#0F5C5B',
            tension: 0.4,
            fill: true
          },
          {
            label: 'Counterfeit',
            data: scansOverTime.counterfeit,
            borderColor: '#FA5716',
            backgroundColor: 'rgba(250, 87, 22, 0.1)',
            borderWidth: 2,
            pointBackgroundColor: '#FA5716',
            tension: 0.4,
            fill: true
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { position: 'top', align: 'end', labels: { usePointStyle: true, pointStyle: 'circle' } }, tooltip: tooltipSettings },
        scales: {
          x: { grid: { display: false, drawBorder: false } },
          y: { grid: { color: 'rgba(0,0,0,0.04)', drawBorder: false }, beginAtZero: true, ticks: { precision: 0 } }
        }
      }
    });

    // 3. Top Products (Bar)
    new Chart(document.getElementById('productChart'), {
      type: 'bar',
      data: {
        labels: prodData.labels,
        datasets: [
          { label: 'Genuine', data: prodData.genuine, backgroundColor: '#0F5C5B', borderRadius: 4 },
          { label: 'Counterfeit', data: prodData.counterfeit, backgroundColor: '#FA5716', borderRadius: 4 }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'top', align: 'end', labels: { usePointStyle: true, pointStyle: 'circle' } }, tooltip: tooltipSettings },
        scales: {
          x: { stacked: true, grid: { display: false } },
          y: { stacked: true, grid: { color: 'rgba(0,0,0,0.04)' }, beginAtZero: true, ticks: { precision: 0 } }
        }
      }
    });

    // 4. Device Analytics (Horizontal Bar)
    new Chart(document.getElementById('deviceChart'), {
      type: 'bar',
      data: {
        labels: deviceData.labels,
        datasets: [
          { label: 'Genuine', data: deviceData.genuine, backgroundColor: '#0F5C5B', borderRadius: 4 },
          { label: 'Counterfeit', data: deviceData.counterfeit, backgroundColor: '#FA5716', borderRadius: 4 }
        ]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'top', align: 'end', labels: { usePointStyle: true, pointStyle: 'circle' } }, tooltip: tooltipSettings },
        scales: {
          x: { stacked: true, grid: { color: 'rgba(0,0,0,0.04)' }, beginAtZero: true, ticks: { precision: 0 } },
          y: { stacked: true, grid: { display: false } }
        }
      }
    });

    // 5. Geographic Activity (Bar)
    new Chart(document.getElementById('geoChart'), {
      type: 'bar',
      data: {
        labels: geoData.labels,
        datasets: [
          { label: 'Genuine', data: geoData.genuine, backgroundColor: '#0F5C5B', borderRadius: 4 },
          { label: 'Counterfeit', data: geoData.counterfeit, backgroundColor: '#FA5716', borderRadius: 4 }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'top', align: 'end', labels: { usePointStyle: true, pointStyle: 'circle' } }, tooltip: tooltipSettings },
        scales: {
          x: { grid: { display: false } },
          y: { grid: { color: 'rgba(0,0,0,0.04)' }, beginAtZero: true, ticks: { precision: 0 } }
        }
      }
    });
  </script>

</body>

</html>
