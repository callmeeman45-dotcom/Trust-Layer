<!DOCTYPE html>
<html>
<head>
  <title>Generate Analytics Report</title>
  <style>
    body { font-family: sans-serif; padding: 40px; background: #f9fafb; }
    h1 { color: #1f2937; }
    .card {
      background: white; border-radius: 12px;
      padding: 32px; max-width: 500px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .upload-area {
      border: 2px dashed #d1d5db; border-radius: 8px;
      padding: 40px; text-align: center;
      color: #6b7280; margin-bottom: 20px; cursor: pointer;
    }
    .upload-area:hover { border-color: #6366f1; color: #6366f1; }
    input[type="file"] { display: none; }
    button {
      width: 100%; padding: 12px;
      background: #6366f1; color: white;
      border: none; border-radius: 8px;
      font-size: 15px; cursor: pointer;
    }
    button:hover { background: #4f46e5; }
    #status { margin-top: 16px; color: #6b7280; font-size: 14px; text-align: center; }
    #status.error { color: #ef4444; }
    #status.success { color: #22c55e; }
  </style>
</head>
<body>
  <h1>Analytics Report Generator</h1>
  <p style="color:#6b7280">Upload your CSV file and get a full PDF analytics report</p>

  <div class="card">
    <div class="upload-area" onclick="document.getElementById('csvFile').click()">
      <p style="font-size:32px; margin:0">📂</p>
      <p id="file-label">Click to select your CSV file</p>
    </div>

    <input type="file" id="csvFile" accept=".csv"
           onchange="document.getElementById('file-label').textContent = this.files[0].name"/>

    <button onclick="uploadAndGenerate()">Generate PDF Report</button>
    <p id="status"></p>
  </div>

  <script>
    async function uploadAndGenerate() {
      const fileInput = document.getElementById("csvFile");
      const status = document.getElementById("status");

      if (!fileInput.files[0]) {
        status.className = "error";
        status.textContent = "Please select a CSV file first.";
        return;
      }

      status.className = "";
      status.textContent = "Generating report, please wait...";

      const formData = new FormData();
      formData.append("file", fileInput.files[0]);

      try {
        // directly calling Python FastAPI
        const response = await fetch("http://localhost:8000/generate-report", {
          method: "POST",
          body: formData
        });

        if (!response.ok) throw new Error("Server error");

        // download the PDF automatically
        const blob = await response.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "scan_report.pdf";
        a.click();

        status.className = "success";
        status.textContent = "Report downloaded successfully!";

      } catch (err) {
        status.className = "error";
        status.textContent = "Failed to generate report. Is the Python server running?";
      }
    }
  </script>
</body>
</html>