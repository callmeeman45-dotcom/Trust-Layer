<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>QR Verification — <%= product.name %></title>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"/>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --ink:#060c06;
  --surface:#0a0f0a;
  --card:#0d1a0d;
  --card2:#111811;
  --border:#1a3a1a;
  --border2:#2d7a2d;
  --g50:#e8f5e8;
  --g100:#c8e6c8;
  --g200:#a5d6a7;
  --g400:#66bb6a;
  --g500:#4caf50;
  --g600:#2d7a2d;
  --g700:#1a4d1a;
  --text-primary:#f0faf0;
  --text-secondary:#a8d8a8;
  --text-muted:#6aaa6a;
  --text-dim:#3a6b3a;
}

html{scroll-behavior:smooth}
body{
  font-family:'Outfit',system-ui,sans-serif;
  background:var(--surface);
  color:var(--text-primary);
  min-height:100vh;
  overflow-x:hidden;
}

/* ── NAVBAR ── */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 48px;height:68px;
  background:rgba(6,12,6,0.97);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.nav-brand{
  display:flex;align-items:center;gap:10px;
  font-size:17px;font-weight:500;color:var(--g200);
  letter-spacing:.03em;text-decoration:none;
}
.nav-brand-icon{
  width:32px;height:32px;background:var(--g700);
  border:1px solid var(--border2);
  border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{
  font-size:11px;letter-spacing:.18em;text-transform:uppercase;
  color:var(--text-muted);text-decoration:none;font-weight:400;transition:color .2s;
}
.nav-links a:hover{color:var(--text-secondary)}
.nav-cta{
  font-size:11px;letter-spacing:.18em;text-transform:uppercase;font-weight:500;
  padding:9px 20px;background:var(--g600);color:var(--g50);
  border:none;cursor:pointer;transition:background .2s;
  font-family:'Outfit',sans-serif;border-radius:4px;
}
.nav-cta:hover{background:var(--g500)}

/* ── HERO ── */
.hero{
  padding-top:68px;
  display:grid;grid-template-columns:1fr 1fr;
  min-height:100vh;
}

.hero-left{
  background:var(--ink);
  padding:80px 60px 80px 48px;
  display:flex;flex-direction:column;justify-content:center;
  border-right:1px solid var(--border);
}

.verified-chip{
  display:inline-flex;align-items:center;gap:8px;
  border:1px solid var(--border2);
  background:rgba(45,122,45,.12);
  padding:7px 18px;border-radius:100px;
  margin-bottom:36px;align-self:flex-start;
}
.chip-dot{
  width:7px;height:7px;border-radius:50%;background:var(--g500);
  animation:pulse 2s ease infinite;
}
@keyframes pulse{
  0%,100%{box-shadow:0 0 0 0 rgba(76,175,80,.4)}
  50%{box-shadow:0 0 0 6px rgba(76,175,80,0)}
}
.verified-chip span{
  font-size:10px;letter-spacing:.3em;text-transform:uppercase;
  color:var(--g400);font-weight:500;
}

.hero-eyebrow{
  font-size:9px;letter-spacing:.4em;text-transform:uppercase;
  color:var(--text-dim);margin-bottom:14px;font-weight:400;
}
.hero-title{
  font-size:clamp(2.4rem,4vw,3.2rem);
  font-weight:600;line-height:1.1;color:var(--text-primary);
  margin-bottom:12px;letter-spacing:-.01em;
}
.hero-title em{font-style:italic;color:var(--g400);font-weight:500}
.hero-subtitle{
  font-size:14px;color:var(--text-secondary);
  font-weight:400;line-height:1.85;margin-bottom:44px;
  max-width:380px;letter-spacing:.02em;
}

.scan-pill{
  display:inline-flex;align-items:center;gap:10px;
  background:rgba(45,122,45,.1);
  border:1px solid rgba(45,122,45,.35);
  padding:12px 20px;border-radius:6px;
}
.scan-pill-dot{
  width:8px;height:8px;border-radius:50%;background:var(--g500);
  animation:pulse 1.8s ease infinite;
}
.scan-pill span{font-size:11px;letter-spacing:.15em;color:var(--text-muted);font-weight:400;}
.scan-pill strong{font-size:11px;color:var(--g400);letter-spacing:.08em;font-weight:500;}

.cert-number{
  font-size:11px;letter-spacing:.25em;
  color:var(--text-dim);
  border-top:1px solid var(--border);
  padding-top:24px;margin-top:auto;font-weight:400;
}
.cert-number strong{color:var(--g400);font-weight:500;}

/* Hero right */
.hero-right{position:relative;overflow:hidden;}

.zoom-container{
  position:relative;width:100%;height:100%;
  overflow:hidden;cursor:zoom-in;
  min-height:500px;
}
.zoom-container img{
  width:100%;height:100%;object-fit:cover;
  transition:transform .1s ease;
  filter:brightness(.85) saturate(.95);
}
.zoom-lens{
  position:absolute;width:180px;height:180px;border-radius:50%;
  border:2px solid rgba(76,175,80,.6);
  box-shadow:0 10px 30px rgba(0,0,0,.4);
  pointer-events:none;opacity:0;
}
.zoom-container::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(to top,rgba(6,12,6,.65) 0%,transparent 55%);
}

.img-stamp{position:absolute;bottom:32px;left:32px;z-index:10;}
.stamp-box{
  background:var(--g600);padding:11px 20px;border-radius:4px;
  display:flex;align-items:center;gap:9px;
}
.stamp-box span{
  font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--g50);font-weight:500;
}
.stamp-check{
  width:17px;height:17px;border:1px solid rgba(255,255,255,.5);
  border-radius:50%;display:flex;align-items:center;justify-content:center;
}

/* ── DETAIL SECTION ── */
.detail-section{
  padding:72px 48px;
  display:grid;grid-template-columns:1.1fr .9fr;
  gap:40px;
  background:var(--surface);
}

.info-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:48px 44px;
  position:relative;
}

.info-tag{
  font-size:9px;letter-spacing:.38em;text-transform:uppercase;
  color:var(--g500);margin-bottom:14px;font-weight:500;
  display:flex;align-items:center;gap:10px;
}
.info-tag::after{content:'';flex:1;height:1px;background:var(--border)}

.info-name{
  font-size:clamp(1.7rem,2.5vw,2.2rem);
  font-weight:600;color:var(--text-primary);margin-bottom:10px;line-height:1.2;
}
.info-price{
  font-size:14px;color:var(--text-secondary);letter-spacing:.05em;
  margin-bottom:0;font-weight:400;
}
.info-price strong{
  font-size:24px;font-weight:600;color:var(--g400);
}
.info-desc{
  font-size:13px;color:var(--text-secondary);line-height:1.9;
  font-weight:400;margin:22px 0 34px;
  padding-left:16px;border-left:2px solid var(--border2);
  letter-spacing:.02em;
}

/* Table */
.dtable{width:100%;border-collapse:collapse}
.dtable tr{border-bottom:1px solid var(--border)}
.dtable tr:last-child{border:none}
.dtable td{padding:13px 0;vertical-align:top}

.dk{
  font-size:10px;letter-spacing:.22em;text-transform:uppercase;
  color:var(--text-muted);font-weight:400;width:42%;padding-top:15px;
}
.dv{
  font-size:14px;color:var(--text-primary);font-weight:500;
  letter-spacing:.02em;text-align:right;line-height:1.5;
}
.dv.hc{color:var(--g400);font-family:monospace;font-size:13px;font-weight:500;}
.dv.green{
  color:var(--g400);
  display:flex;align-items:center;gap:6px;justify-content:flex-end;
  font-weight:500;
}
.dv.green::before{
  content:'';width:7px;height:7px;border-radius:50%;
  background:var(--g500);
  animation:pulse 2s ease infinite;
}

/* Back button */
.btn-back{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--g600);color:var(--g50);
  padding:13px 28px;border:none;cursor:pointer;
  font-family:'Outfit',sans-serif;font-size:11px;
  letter-spacing:.22em;text-transform:uppercase;font-weight:500;
  text-decoration:none;transition:background .2s;
  margin-top:12px;border-radius:4px;
}
.btn-back:hover{background:var(--g500);color:var(--g50)}

/* Side col */
.side-col{display:flex;flex-direction:column;gap:20px}

/* Hash card */
.hash-card{
  background:var(--ink);
  border:1px solid var(--border);
  border-radius:12px;
  padding:28px 32px;
}
.hash-label{
  font-size:9px;letter-spacing:.32em;text-transform:uppercase;
  color:var(--text-dim);margin-bottom:14px;font-weight:400;
}
.hash-val{
  font-size:13px;color:var(--g400);
  letter-spacing:.08em;line-height:1.85;word-break:break-all;
  font-family:monospace;font-weight:400;
}
.hash-bottom{
  margin-top:18px;padding-top:18px;
  border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.hash-ts{font-size:10px;color:var(--text-dim);letter-spacing:.12em;font-weight:400;}

/* Provenance card */
.prov-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:28px 32px;
}
.prov-title{
  font-size:16px;font-weight:600;
  color:var(--text-primary);margin-bottom:5px;
}
.prov-sub{font-size:11px;color:var(--text-muted);letter-spacing:.14em;margin-bottom:22px;font-weight:400;}
.prov-steps{display:flex;flex-direction:column;}
.prov-step{display:flex;gap:14px;position:relative;}
.prov-step:not(:last-child)::after{
  content:'';position:absolute;left:8px;top:22px;
  width:1px;height:calc(100%);
  background:var(--border);
}
.prov-dot{
  width:17px;height:17px;border-radius:50%;border:1px solid var(--border2);
  background:var(--ink);display:flex;align-items:center;justify-content:center;
  flex-shrink:0;margin-top:2px;
}
.prov-dot-in{width:6px;height:6px;border-radius:50%;background:var(--g500)}
.prov-info{padding-bottom:18px;}
.prov-lbl{
  font-size:10px;letter-spacing:.18em;text-transform:uppercase;
  color:var(--text-muted);font-weight:400;margin-bottom:4px;
}
.prov-val{font-size:13px;color:var(--text-primary);font-weight:500;letter-spacing:.02em;}

/* Footer */
.footer{
  background:var(--ink);
  padding:36px 48px;
  display:flex;align-items:center;justify-content:space-between;
  border-top:1px solid var(--border);
  flex-wrap:wrap;gap:16px;
}
.footer-brand{
  font-size:15px;color:var(--text-muted);font-weight:400;letter-spacing:.06em;
}
.footer-brand strong{color:var(--g400);font-weight:500;}
.footer-copy{font-size:10px;letter-spacing:.14em;color:var(--text-dim);font-weight:400;}
.footer-links{display:flex;gap:26px;}
.footer-links a{
  font-size:10px;letter-spacing:.18em;text-transform:uppercase;
  color:var(--text-dim);text-decoration:none;transition:color .2s;font-weight:400;
}
.footer-links a:hover{color:var(--text-secondary)}

/* PDF Modal */
.pdf-modal{
  display:none;position:fixed;z-index:9999;
  left:0;top:0;width:100%;height:100%;
  background:rgba(0,0,0,.75);
}
.pdf-container{
  position:relative;width:80%;height:85%;
  margin:3% auto;background:var(--card);
  border-radius:12px;overflow:hidden;
  border:1px solid var(--border);
}
.pdf-container iframe{width:100%;height:100%;border:none;}
.close-btn{
  position:absolute;top:12px;right:16px;font-size:22px;
  cursor:pointer;color:var(--text-secondary);z-index:10;
  width:32px;height:32px;display:flex;align-items:center;justify-content:center;
  background:var(--ink);border-radius:50%;border:1px solid var(--border);
}
.close-btn:hover{color:var(--text-primary)}

/* Lab card */
.lab-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:22px 28px;
  display:flex;align-items:center;gap:18px;
  cursor:pointer;transition:border-color .25s;text-decoration:none;
}
.lab-card:hover{border-color:var(--border2);}
.lab-icon{
  width:44px;height:44px;background:rgba(45,122,45,.15);border:1px solid var(--border);
  border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.lab-ttl{font-size:13px;font-weight:500;color:var(--text-primary);margin-bottom:3px;}
.lab-st{font-size:11px;color:var(--text-muted);letter-spacing:.08em;font-weight:400;}
.lab-arr{margin-left:auto;color:var(--text-dim);transition:transform .25s,color .25s;}
.lab-card:hover .lab-arr{transform:translateX(4px);color:var(--g500)}

@media(max-width:900px){
  .nav{padding:0 16px}.nav-links{display:none}
  .hero{grid-template-columns:1fr}
  .hero-left{padding:52px 20px}
  .zoom-container{min-height:300px}
  .detail-section{grid-template-columns:1fr;padding:40px 16px}
  .info-card{padding:32px 20px}
  .hash-card,.prov-card,.lab-card{padding:22px 18px}
  .footer{flex-direction:column;gap:16px;padding:28px 16px}
}
</style>
</head>
