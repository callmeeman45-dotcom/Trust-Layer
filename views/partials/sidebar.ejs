<!-- SIDEBAR OVERLAY -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleMobileSidebar()"></div>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-brand-icon">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M9 2L3 6v4c0 3.3 2.5 6.4 6 7.2C12.5 16.4 15 13.3 15 10V6L9 2z" fill="white" opacity=".9" />
        <path d="M7 9.5l1.5 1.5 3-3" stroke="rgba(200,130,26,0.9)" stroke-width="1.4" stroke-linecap="round"
          stroke-linejoin="round" />
      </svg>
    </div>
    <div class="sb-brand-name">Trust Layer</div>
  </div>

  <nav class="sb-nav">
    <div class="sb-nav-label">Workspace</div>

    <a class="sb-link <%= typeof active !== 'undefined' && active === 'overview' ? 'active' : '' %>" href="/admin/space" onclick="setActive(this)" style="text-decoration: none;">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2" />
        <rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2" />
        <rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2" />
        <rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2" />
      </svg>
      Dashboard
    </a>

    <a class="sb-link <%= typeof active !== 'undefined' && active === 'all-products' ? 'active' : '' %>" href="/all-products" onclick="setActive(this)" style="text-decoration: none;">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <path d="M2 4h12M2 8h8M2 12h5" stroke="currentColor" stroke-width="1.2" />
      </svg>
      All Products
    </a>

    <a class="sb-link <%= typeof active !== 'undefined' && active === 'add-product' ? 'active' : '' %>" href="/add-product" onclick="setActive(this)" style="text-decoration: none;">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <rect x="2" y="2" width="5" height="5" rx=".5" stroke="currentColor" stroke-width="1.2" />
        <rect x="9" y="2" width="5" height="5" rx=".5" stroke="currentColor" stroke-width="1.2" />
        <rect x="2" y="9" width="5" height="5" rx=".5" stroke="currentColor" stroke-width="1.2" />
        <path d="M11.5 9v5M9 11.5h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
      </svg>
      Add Product
    </a>

    <a class="sb-link <%= typeof active !== 'undefined' && active === 'analytics' ? 'active' : '' %>" href="/analytics" onclick="setActive(this)" style="text-decoration: none;">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <path d="M2 14h12M4 11l3-3 2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Analytics
    </a>

    <a class="sb-link <%= typeof active !== 'undefined' && active === 'knowledge-base' ? 'active' : '' %>" href="/admin/knowledge-base" onclick="setActive(this)" style="text-decoration: none;">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <path d="M4 2h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z" stroke="currentColor"
          stroke-width="1.2" />
        <path d="M6 6h4M6 10h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
      </svg>
      Knowledge Base
    </a>

    <div class="sb-nav-label" style="margin-top:8px">Tools</div>
    <a class="sb-link <%= typeof active !== 'undefined' && active === 'scan-monitor' ? 'active' : '' %>" href="/admin/dashboard" style="text-decoration: none;">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="5" stroke="currentColor" stroke-width="1.2" />
        <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.2" />
        <path d="M8 1v2M8 13v2M1 8h2M13 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
      </svg>
      Scan Monitor
    </a>
    <div class="sb-link" onclick="setActive(this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2" />
        <path d="M5 7h6M5 10h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
      </svg>
      Lab Reports
    </div>
    <div class="sb-link" onclick="setActive(this)">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.2" />
        <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
      </svg>
      Account
    </div>
  </nav>

  <form action="/logout" method="POST">
    <div class="sb-bottom">
      <button class="logout-btn-animated" type="submit">
        <div class="sign">
          <svg viewBox="0 0 16 16" fill="none">
            <path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M11 5l3 3-3 3M14 8H7" stroke="currentColor" stroke-width="1.2"
              stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div class="text">Logout</div>
      </button>
    </div>
  </form>
</aside>

<script>
  function toggleMobileSidebar() {
    const sidebar = document.querySelector('.sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    if (sidebar && overlay) {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('show');
    }
  }
</script>