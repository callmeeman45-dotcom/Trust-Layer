
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  .ap-wrap { background: #0a0f0a; font-family: system-ui, sans-serif; padding: 24px 20px 40px; }
  .ap-nav { display: flex; align-items: center; justify-content: space-between; padding: 0 0 24px; border-bottom: 1px solid #1a3a1a; margin-bottom: 32px; }
  .ap-logo { display: flex; align-items: center; gap: 10px; font-size: 16px; font-weight: 500; color: #a8e6a8; }
  .ap-logo-icon { width: 30px; height: 30px; background: #1a4d1a; border: 1px solid #2d7a2d; border-radius: 7px; display: flex; align-items: center; justify-content: center; }
  .ap-nav-back { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: #3a6b3a; background: transparent; border: 1px solid #1a3a1a; padding: 8px 18px; cursor: pointer; font-family: inherit; border-radius: 4px; text-decoration: none; transition: border-color 0.2s, color 0.2s; display: inline-block; }
  .ap-nav-back:hover { border-color: #2d7a2d; color: #a8e6a8; }
  .ap-grid { display: grid; grid-template-columns: 1fr 1.7fr; gap: 40px; align-items: start; }
  .ap-eyebrow { font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; color: #2d7a2d; margin-bottom: 14px; font-weight: 400; }
  .ap-h1 { font-size: 2rem; font-weight: 500; line-height: 1.1; color: #e8f5e8; margin-bottom: 14px; letter-spacing: -0.02em; }
  .ap-h1 em { font-style: italic; color: #4caf50; }
  .ap-desc { font-size: 12px; color: #3a6b3a; line-height: 1.8; margin-bottom: 32px; }
  .ap-steps { display: flex; flex-direction: column; }
  .ap-step { display: flex; gap: 14px; position: relative; }
  .ap-step:not(:last-child)::after { content: ''; position: absolute; left: 10px; top: 24px; width: 1px; height: calc(100% + 2px); background: #1a3a1a; }
  .ap-step-num { width: 20px; height: 20px; border-radius: 50%; border: 1px solid #2d7a2d; background: #0d1a0d; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; font-size: 10px; color: #4caf50; font-weight: 500; }
  .ap-step-body { padding-bottom: 20px; }
  .ap-step-label { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #2d7a2d; margin-bottom: 3px; }
  .ap-step-val { font-size: 12px; color: #3a6b3a; }
  .ap-cert { margin-top: 8px; border-top: 1px solid #1a3a1a; padding-top: 20px; font-size: 11px; letter-spacing: 0.2em; color: #1a3a1a; }
  .ap-cert strong { color: #4caf50; font-weight: 400; }
  .ap-card { background: #0d1a0d; border: 1px solid #1a3a1a; border-radius: 10px; overflow: hidden; }
  .ap-card-head { background: #060c06; padding: 24px 32px; display: flex; align-items: center; gap: 16px; border-bottom: 1px solid #1a3a1a; }
  .ap-card-head-icon { width: 42px; height: 42px; background: #0d2a0d; border: 1px solid #2d7a2d; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ap-card-head-title { font-size: 16px; font-weight: 500; color: #e8f5e8; margin-bottom: 3px; }
  .ap-card-head-title em { font-style: italic; color: #4caf50; }
  .ap-card-head-sub { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: #2d7a2d; }
  .ap-card-body { padding: 28px 32px 32px; }
  .ap-sec-lbl { font-size: 9px; letter-spacing: 0.38em; text-transform: uppercase; color: #2d7a2d; display: flex; align-items: center; gap: 10px; margin-bottom: 18px; margin-top: 28px; }
  .ap-sec-lbl:first-child { margin-top: 0; }
  .ap-sec-lbl::after { content: ''; flex: 1; height: 1px; background: #1a3a1a; }
  .ap-field { margin-bottom: 14px; }
  .ap-field label { display: block; font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: #3a6b3a; margin-bottom: 7px; }
  .ap-input { width: 100%; padding: 11px 14px; background: #111811; border: 1px solid #1a3a1a; border-radius: 4px; font-family: inherit; font-size: 13px; color: #a8e6a8; letter-spacing: 0.03em; outline: none; transition: border-color 0.2s; }
  .ap-input:focus { border-color: #2d7a2d; box-shadow: 0 0 0 3px rgba(45,122,45,0.15); }
  .ap-input::placeholder { color: #1a3a1a; font-size: 12px; }
  .ap-input[type="date"] { color: #5a8c5a; }
  .ap-input[type="date"]::-webkit-calendar-picker-indicator { opacity: 0.3; filter: invert(1); cursor: pointer; }
  .ap-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ap-file-wrap { border: 1px dashed #1a3a1a; background: #111811; border-radius: 4px; padding: 16px 14px; display: flex; align-items: center; gap: 12px; cursor: pointer; position: relative; transition: border-color 0.2s; }
  .ap-file-wrap:hover { border-color: #2d7a2d; }
  .ap-file-wrap input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
  .ap-file-icon { width: 32px; height: 32px; background: #0d2a0d; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ap-file-main { font-size: 12px; color: #5a8c5a; }
  .ap-file-sub { font-size: 10px; color: #1a3a1a; letter-spacing: 0.1em; margin-top: 2px; }
  .ap-btn { width: 100%; padding: 15px; background: #2d7a2d; color: #e8f5e8; border: none; cursor: pointer; font-family: inherit; font-size: 11px; letter-spacing: 0.35em; text-transform: uppercase; font-weight: 400; margin-top: 28px; display: flex; align-items: center; justify-content: center; gap: 10px; border-radius: 4px; transition: background 0.2s; }
  .ap-btn:hover { background: #3a9e3a; }
  .ap-btn:active { transform: scale(0.998); }
</style>

<div class="ap-wrap">
  <h2 class="sr-only">Add new product batch — Trust Layer form</h2>

  <nav class="ap-nav">
    <div class="ap-logo">
      <div class="ap-logo-icon">
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
          <path d="M9 2L3 6v4c0 3.3 2.5 6.4 6 7.2C12.5 16.4 15 13.3 15 10V6L9 2z" fill="#4caf50" opacity="0.9"/>
          <path d="M7 9.5l1.5 1.5 3-3" stroke="#0d1a0d" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      Trust Layer
    </div>
    <a href="/" class="ap-nav-back">← Back to home</a>
  </nav>

  <div class="ap-grid">

    <div class="ap-left">
      <p class="ap-eyebrow">Product management portal</p>
      <h1 class="ap-h1">Register a<br><em>new batch</em></h1>
      <p class="ap-desc">Fill in the product details to generate unique QR codes for each unit. Every item receives a tamper-proof certificate tied to your registry.</p>

      <div class="ap-steps">
        <div class="ap-step">
          <div class="ap-step-num">1</div>
          <div class="ap-step-body">
            <p class="ap-step-label">Product details</p>
            <p class="ap-step-val">Name, description, batch number, price</p>
          </div>
        </div>
        <div class="ap-step">
          <div class="ap-step-num">2</div>
          <div class="ap-step-body">
            <p class="ap-step-label">Dates & quantity</p>
            <p class="ap-step-val">Manufacturing date, expiry, units to generate</p>
          </div>
        </div>
        <div class="ap-step">
          <div class="ap-step-num">3</div>
          <div class="ap-step-body">
            <p class="ap-step-label">QR generation</p>
            <p class="ap-step-val">Unique codes per unit, registered to Trust Layer</p>
          </div>
        </div>
      </div>

      <div class="ap-cert">Powered by &nbsp;<strong>Trust Layer Registry</strong></div>
    </div>

    <div class="ap-card">
      <div class="ap-card-head">
        <div class="ap-card-head-icon">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none">
            <rect x="2" y="2" width="7" height="7" rx=".5" stroke="#4caf50" stroke-width="1.3"/>
            <rect x="13" y="2" width="7" height="7" rx=".5" stroke="#4caf50" stroke-width="1.3"/>
            <rect x="2" y="13" width="7" height="7" rx=".5" stroke="#4caf50" stroke-width="1.3"/>
            <path d="M13 13h2M13 17h2M17 13v2M17 17v2" stroke="#4caf50" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <p class="ap-card-head-title">Add new <em>product batch</em></p>
          <p class="ap-card-head-sub">Generate QR codes for each unit</p>
        </div>
      </div>

      <div class="ap-card-body">
        <form action="/add-product" method="POST" enctype="multipart/form-data">

          <p class="ap-sec-lbl">Product information</p>

          <div class="ap-field">
            <label>Product name</label>
            <input class="ap-input" type="text" name="name" placeholder="e.g. Raw Wildflower Honey 350g" required/>
          </div>

          <div class="ap-field">
            <label>Description</label>
            <input class="ap-input" type="text" name="description" placeholder="e.g. Cold-extracted, unfiltered, single origin" required/>
          </div>

          <div class="ap-grid2">
            <div class="ap-field">
              <label>Batch number</label>
              <input class="ap-input" type="text" name="batchNumber" placeholder="e.g. AH-2025-WF001" required/>
            </div>
            <div class="ap-field">
              <label>Price (RS)</label>
              <input class="ap-input" type="number" name="price" placeholder="e.g. 1200" step="0.01" required/>
            </div>
          </div>

          <p class="ap-sec-lbl">Dates & stock</p>

          <div class="ap-grid2">
            <div class="ap-field">
              <label>Manufacturing date</label>
              <input class="ap-input" type="date" name="manufacturingDate" required/>
            </div>
            <div class="ap-field">
              <label>Expiry date</label>
              <input class="ap-input" type="date" name="expiryDate" required/>
            </div>
          </div>

          <div class="ap-grid2">
            <div class="ap-field">
              <label>Quantity (units)</label>
              <input class="ap-input" type="number" name="quantity" placeholder="e.g. 500" required/>
            </div>
            <div class="ap-field">
              <label>Product image</label>
              <div class="ap-file-wrap">
                <input type="file" name="image" id="ap-image" accept="image/*" required/>
                <div class="ap-file-icon">
                  <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
                    <rect x="2" y="4" width="14" height="11" rx="1" stroke="#4caf50" stroke-width="1.2"/>
                    <circle cx="6.5" cy="8.5" r="1.5" stroke="#4caf50" stroke-width="1.1"/>
                    <path d="M2 12l4-3 3 2.5 3-3 4 3.5" stroke="#4caf50" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div>
                  <p class="ap-file-main" id="ap-file-label">Choose image</p>
                  <p class="ap-file-sub">JPG · PNG · WEBP</p>
                </div>
              </div>
            </div>
          </div>

          <button type="submit" class="ap-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <rect x="1" y="1" width="5" height="5" rx=".4" stroke="currentColor" stroke-width="1.2"/>
              <rect x="8" y="1" width="5" height="5" rx=".4" stroke="currentColor" stroke-width="1.2"/>
              <rect x="1" y="8" width="5" height="5" rx=".4" stroke="currentColor" stroke-width="1.2"/>
              <path d="M8 8h2M8 11h2M11 8v2M11 11v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            Generate products & QR codes
          </button>

        </form>
      </div>
    </div>

  </div>
</div>

<script>
document.getElementById('ap-image').addEventListener('change', function(){
  const lbl = document.getElementById('ap-file-label');
  lbl.textContent = this.files[0] ? this.files[0].name : 'Choose image';
});
</script>
