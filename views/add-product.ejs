<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Product — Trust Layer</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Outfit:wght@200;300;400;500&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/dashboard-layout.css">
  <style>
    /* ── FORM CONTAINER ── */
    .form-container {
      max-width: 720px;
      margin: 0 auto;
      padding: 10px 0 40px;
    }

    .form-eyebrow {
      display:flex;align-items:center;gap:10px;
      font-size:8px;letter-spacing:.45em;text-transform:uppercase;
      color:var(--honey);font-weight:300;margin-bottom:28px;
    }
    .form-eyebrow::after{content:'';flex:0 0 36px;height:1px;background:var(--beige)}

    /* section labels */
    .form-section {
      font-size:8px;letter-spacing:.4em;text-transform:uppercase;
      color:var(--warm);font-weight:300;
      margin-bottom:14px;margin-top:32px;
      display:flex;align-items:center;gap:10px;
    }
    .form-section::after{content:'';flex:1;height:1px;background:var(--beige)}
    .form-section:first-of-type{margin-top:0}

    /* field group */
    .field{margin-bottom:16px}
    .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:0}
    .field-row .field{margin-bottom:0}

    label {
      display:block;
      font-size:10px;font-weight:400;letter-spacing:.2em;text-transform:uppercase;
      color:var(--umber);margin-bottom:8px;
    }

    input[type="text"],
    input[type="number"],
    input[type="date"],
    textarea {
      width: 100%;
      height: 48px;
      border: 3px solid transparent;
      outline: none;
      caret-color: var(--honey);
      background-image: linear-gradient(var(--white), var(--white)), 
                        linear-gradient(to bottom, rgba(250, 87, 22, 0.15), rgba(15, 92, 91, 0.15));
      background-origin: border-box;
      background-clip: padding-box, border-box;
      border-radius: 30px;
      padding: 0 20px;
      letter-spacing: 0.8px;
      color: var(--ink);
      font-size: 13px;
      font-family: 'Outfit', sans-serif;
      box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.04);
      transition: all 0.25s ease;
      box-sizing: border-box;
    }

    textarea {
      height: auto;
      min-height: 100px;
      padding: 14px 20px;
      border-radius: 20px;
      resize: vertical;
      line-height: 1.7;
    }

    input[type="text"]:focus,
    input[type="number"]:focus,
    input[type="date"]:focus,
    textarea:focus {
      background-image: linear-gradient(var(--white), var(--white)), 
                        linear-gradient(to bottom, var(--honey), var(--amber));
      box-shadow: 0 0 12px rgba(250, 87, 22, 0.12);
    }

    input::placeholder,textarea::placeholder{color:var(--umber) !important;font-weight:300;opacity:0.75}

    /* date input */
    input[type="date"]{color-scheme:light}
    input[type="date"]::-webkit-calendar-picker-indicator {
      opacity:.4;cursor:pointer;filter:sepia(1);
    }

    /* ── UIVERSE FOLDER UPLOAD UX ── */
    .upload-container {
      --transition: 350ms;
      --folder-W: 120px;
      --folder-H: 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      padding: 16px;
      background: linear-gradient(135deg, var(--amber), #073837);
      border-radius: 15px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
      height: calc(var(--folder-H) * 1.8);
      position: relative;
      overflow: visible;
      margin-top: 10px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .upload-folder {
      position: absolute;
      top: 14px;
      left: calc(50% - 60px);
      animation: float 2.5s infinite ease-in-out;
      transition: transform var(--transition) ease;
    }

    .upload-folder:hover {
      transform: scale(1.05);
    }

    .upload-folder .front-side,
    .upload-folder .back-side {
      position: absolute;
      transition: transform var(--transition);
      transform-origin: bottom center;
    }

    .upload-folder .back-side::before,
    .upload-folder .back-side::after {
      content: "";
      display: block;
      background-color: white;
      opacity: 0.5;
      width: var(--folder-W);
      height: var(--folder-H);
      position: absolute;
      transform-origin: bottom center;
      border-radius: 15px;
      transition: transform 350ms;
      z-index: 0;
    }

    .upload-container:hover .back-side::before {
      transform: rotateX(-5deg) skewX(5deg);
    }
    .upload-container:hover .back-side::after {
      transform: rotateX(-15deg) skewX(12deg);
    }

    .upload-folder .front-side {
      z-index: 1;
    }

    .upload-container:hover .front-side {
      transform: rotateX(-40deg) skewX(15deg);
    }

    .upload-folder .tip {
      background: linear-gradient(135deg, var(--honey), #ff7034);
      width: 80px;
      height: 20px;
      border-radius: 12px 12px 0 0;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      position: absolute;
      top: -10px;
      z-index: 2;
    }

    .upload-folder .cover {
      background: linear-gradient(135deg, #f8fafc, #e2e8f0);
      width: var(--folder-W);
      height: var(--folder-H);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
      border-radius: 10px;
      border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .custom-file-upload {
      font-size: 11px;
      color: #ffffff;
      text-align: center;
      background: rgba(255, 255, 255, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 10px;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
      cursor: pointer;
      transition: all var(--transition) ease;
      display: inline-block;
      width: auto;
      padding: 10px 28px;
      position: relative;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-family: 'Outfit', sans-serif;
      z-index: 5;
    }

    .custom-file-upload:hover {
      background: rgba(255, 255, 255, 0.3);
      border-color: rgba(255, 255, 255, 0.4);
    }

    .custom-file-upload input[type="file"] {
      display: none;
    }

    .file-name {
      font-size: 11px;
      color: #ffffff;
      margin-top: 8px;
      letter-spacing: .04em;
      font-weight: 500;
      display: none;
      z-index: 5;
      background: rgba(0, 0, 0, 0.25);
      padding: 4px 10px;
      border-radius: 4px;
    }

    @keyframes float {
      0% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-8px);
      }
      100% {
        transform: translateY(0px);
      }
    }

    /* image preview */
    .img-preview {
      width: 100%;
      height: 100%;
      object-fit: contain;
      background: #ffffff;
      display: none;
      position: absolute;
      top: 0;
      left: 0;
      z-index: 10;
      padding: 15px;
    }

    .custom-file-upload.has-image {
      position: absolute;
      bottom: 20px;
      right: 20px;
      background: var(--honey);
      color: #fff;
      border: none;
      box-shadow: 0 4px 15px rgba(0,0,0,0.3);
      padding: 8px 16px;
      z-index: 20;
    }

    /* ── SUBMIT ── */
    .submit-wrap{margin-top:32px}
    .btn-submit {
      width:100%;padding:15px 28px;
      background:var(--ink);color:var(--cream);
      border:none;font-family:'Outfit',sans-serif;
      font-size:11px;letter-spacing:.25em;text-transform:uppercase;font-weight:400;
      cursor:pointer;display:flex;align-items:center;justify-content:center;gap:12px;
      transition:background .25s,transform .2s;position:relative;overflow:hidden;
      border-radius: 6px;
    }
    .btn-submit::before {
      content:'';position:absolute;inset:0;
      background:linear-gradient(90deg,transparent,rgba(200,130,26,.12),transparent);
      transform:translateX(-100%);transition:transform .5s ease;
    }
    .btn-submit:hover{background:var(--bark)}
    .btn-submit:hover::before{transform:translateX(100%)}
    .btn-submit:active{transform:scale(.99)}

    /* ── ANIMATIONS ── */
    @keyframes fadeRight{from{opacity:0;transform:translateX(16px)}to{opacity:1;transform:translateX(0)}}

    /* field stagger */
    .field:nth-child(1){animation:fadeRight .5s .2s ease both}
    .field:nth-child(2){animation:fadeRight .5s .27s ease both}
    .field:nth-child(3){animation:fadeRight .5s .34s ease both}
    .field:nth-child(4){animation:fadeRight .5s .41s ease both}
    .field:nth-child(5){animation:fadeRight .5s .48s ease both}
    .field:nth-child(6){animation:fadeRight .5s .55s ease both}
    .field-row{animation:fadeRight .5s .38s ease both}

    /* ── RESPONSIVE ── */
    @media(max-width:900px){
      .field-row{grid-template-columns:1fr}
    }
  </style>
</head>

<body>

  <%- include('partials/sidebar', { active: 'add-product' }) %>

  <!-- MAIN -->
  <div class="main">

    <%- include('partials/topbar', { pageTitle: 'Add Product', pageSub: 'Register a new item' }) %>

    <!-- CONTENT -->
    <div class="content">
      <div class="form-container">

        <p class="form-eyebrow">New product registration</p>

        <form action="/add-product" method="POST" enctype="multipart/form-data" id="productForm">

          <!-- Product Info -->
          <p class="form-section">Product information</p>

          <div class="field">
            <label for="name">Product name</label>
            <input type="text" id="name" name="name" placeholder="e.g. Sidr Honey 500g" required/>
          </div>

          <div class="field">
            <label for="description">Description</label>
            <textarea id="description" name="description" placeholder="Describe the product — its origin, properties, and what makes it authentic…" required></textarea>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="batchNumber">Batch number</label>
              <input type="text" id="batchNumber" name="batchNumber" placeholder="e.g. TL-0042-SH5" required/>
            </div>
            <div class="field">
              <label for="price">Price (PKR)</label>
              <input type="number" id="price" name="price" placeholder="e.g. 1200" step="0.01" required/>
            </div>
          </div>

          <!-- Dates & Stock -->
          <p class="form-section">Dates &amp; stock</p>

          <div class="field-row">
            <div class="field">
              <label for="manufacturingDate">Manufacturing date</label>
              <input type="date" id="manufacturingDate" name="manufacturingDate" required/>
            </div>
            <div class="field">
              <label for="expiryDate">Expiry date</label>
              <input type="date" id="expiryDate" name="expiryDate" required/>
            </div>
          </div>

          <div class="field">
            <label for="quantity">Quantity (units in batch)</label>
            <input type="number" id="quantity" name="quantity" placeholder="e.g. 500" required/>
          </div>

          <!-- Image upload -->
          <p class="form-section">Product image</p>

          <div class="field">
            <div class="upload-container" id="fileZone">
              <div class="upload-folder" id="uploadFolder">
                <div class="front-side">
                  <div class="tip"></div>
                  <div class="cover"></div>
                </div>
                <div class="back-side">
                  <div class="cover"></div>
                </div>
              </div>
              <label class="custom-file-upload" id="uploadLabel">
                <input type="file" name="image" id="imageInput" accept="image/*" required/>
                <span id="uploadText">Choose Image</span>
              </label>
              <div class="file-name" id="fileName"></div>
              <img class="img-preview" id="imgPreview" alt="Preview"/>
            </div>
          </div>

          <!-- Submit -->
          <div class="submit-wrap">
            <button type="submit" class="btn-submit">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                <rect x="2" y="2" width="7" height="7" rx=".8" stroke="currentColor" stroke-width="1.3"/>
                <rect x="11" y="2" width="7" height="7" rx=".8" stroke="currentColor" stroke-width="1.3"/>
                <rect x="2" y="11" width="7" height="7" rx=".8" stroke="currentColor" stroke-width="1.3"/>
                <path d="M14 11v7M11 14h7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              Generate Products &amp; QR Codes
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>

  <script>
  // File upload UX
  const input = document.getElementById('imageInput');
  const zone  = document.getElementById('fileZone');
  const fname = document.getElementById('fileName');
  const prev  = document.getElementById('imgPreview');

  input.addEventListener('change', function(){
    if(this.files && this.files[0]){
      const reader = new FileReader();
      reader.onload = e => {
        prev.src = e.target.result;
        prev.style.display = 'block';
        document.getElementById('uploadFolder').style.display = 'none';
        document.getElementById('uploadText').innerText = 'Change Image';
        document.getElementById('uploadLabel').classList.add('has-image');
        fname.style.display = 'none';
      };
      reader.readAsDataURL(this.files[0]);
    }
  });

  // Drag states
  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('drag'));
  zone.addEventListener('drop', e => {
    e.preventDefault(); zone.classList.remove('drag');
    if(e.dataTransfer.files[0]){
      input.files = e.dataTransfer.files;
      input.dispatchEvent(new Event('change'));
    }
  });

  // Set today's date as default manufacturing date
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('manufacturingDate').value = today;
  </script>

</body>
</html>