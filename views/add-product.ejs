<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add Product — Trust layer </title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }

body {
  min-height: 100vh;
  background-color: #6e5830;
  background-image: linear-gradient(135deg, #6e5830 0%, #6e5830 50%, #6e5830 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  position: relative;
  overflow-x: hidden;
}

/* Subtle background pattern */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.06) 0%, transparent 50%),
                    radial-gradient(circle at 80% 70%, rgba(255,255,255,0.04) 0%, transparent 50%);
  pointer-events: none;
}

/* ── TOP BRAND BAR ── */
.brand-bar {
  text-align: center;
  margin-bottom: 28px;
  animation: fadeDown 0.5s ease both;
}

.brand-bar a {
  font-size: 26px;
  font-weight: 700;
  color: white;
  text-decoration: none;
  letter-spacing: 0.04em;
}

.brand-bar p {
  font-size: 11px;
  color: rgba(255,255,255,0.65);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-top: 4px;
}

/* ── CARD ── */
.form-card {
  background: white;
  width: 100%;
  max-width: 660px;
  border-radius: 20px;
  box-shadow: 0 30px 70px rgba(0,0,0,0.25), 0 4px 20px rgba(0,0,0,0.1);
  overflow: hidden;
  animation: riseUp 0.6s cubic-bezier(0.22,1,0.36,1) 0.1s both;
}

@keyframes riseUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-12px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Card header strip */
.card-header-strip {
  background: #6e5830;
  background-image: linear-gradient(135deg, #6e5830, #6e5830);
  padding: 28px 40px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.header-icon {
  width: 48px; height: 48px;
  background: rgba(255,255,255,0.18);
  border: 1.5px solid rgba(255,255,255,0.3);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-header-strip h2 {
  font-size: 18px;
  font-weight: 700;
  color: white;
  margin: 0;
}

.card-header-strip p {
  font-size: 11px;
  color: rgba(255,255,255,0.7);
  margin: 2px 0 0;
  letter-spacing: 0.06em;
}

/* ── FORM BODY ── */
.card-body-inner {
  padding: 36px 40px 40px;
}

/* Section divider */
.form-section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #6e5830;
  margin-bottom: 16px;
  margin-top: 28px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.form-section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #f0ece4;
}

.form-section-label:first-child { margin-top: 0; }

/* Two column grid */
.form-row-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.form-group { margin-bottom: 16px; }

label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: #555;
  margin-bottom: 7px;
  letter-spacing: 0.04em;
}

input[type="text"],
input[type="number"],
input[type="date"],
input[type="file"] {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid #e0dbd0;
  border-radius: 10px;
  font-size: 13px;
  font-family: 'Poppins', sans-serif;
  color: #333;
  background: #fdfcf9;
  transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
}

input:focus {
  border-color: #6e5830;
  outline: none;
  box-shadow: 0 0 0 3px rgba(138,118,80,0.12);
  background: white;
}

input::placeholder { color: #bbb; }

/* File input styling */
input[type="file"] {
  padding: 9px 14px;
  cursor: pointer;
  color: #888;
}

input[type="file"]::-webkit-file-upload-button {
  background: #f0ece4;
  border: 1px solid #ddd6c8;
  border-radius: 6px;
  padding: 4px 12px;
  font-size: 11px;
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  color: #6e5830;
  cursor: pointer;
  transition: background 0.2s;
  margin-right: 10px;
}

input[type="file"]::-webkit-file-upload-button:hover {
  background: #e5dfd3;
}

/* ── SUBMIT BUTTON ── */
.btn-submit {
  width: 100%;
  padding: 14px;
  border: none;
  border-radius: 10px;
  background: #6e5830;
  background-image: linear-gradient(135deg, #6e5830, #6e5830, #7a6540);
  color: white;
  font-size: 14px;
  font-weight: 700;
  font-family: 'Poppins', sans-serif;
  cursor: pointer;
  transition: transform 0.25s, box-shadow 0.25s;
  letter-spacing: 0.04em;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-top: 28px;
}

.btn-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(138,118,80,0.4);
}

.btn-submit:active { transform: translateY(0); }

/* QR icon in button */
.btn-submit svg { flex-shrink: 0; }

/* ── FOOTER NOTE ── */
.footer-note {
  text-align: center;
  margin-top: 20px;
  font-size: 11px;
  color: rgba(255,255,255,0.6);
  animation: riseUp 0.5s ease 0.5s both;
}

.footer-note a {
  color: rgba(255,255,255,0.9);
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* RESPONSIVE */
@media (max-width: 600px) {
  .form-row-2 { grid-template-columns: 1fr; }
  .card-header-strip { padding: 22px 24px; }
  .card-body-inner { padding: 24px; }
}
</style>
</head>
<body>

<!-- BRAND -->
<div class="brand-bar">
  <a href="/">Trust layer</a>
  <p>Product Management Portal</p>
</div>

<!-- FORM CARD -->
<div class="form-card">

  <!-- Header -->
  <div class="card-header-strip">
    <div class="header-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <rect x="3" y="3" width="7" height="7" rx="1" stroke="white" stroke-width="1.8"/>
        <rect x="14" y="3" width="7" height="7" rx="1" stroke="white" stroke-width="1.8"/>
        <rect x="3" y="14" width="7" height="7" rx="1" stroke="white" stroke-width="1.8"/>
        <path d="M14 14h2M14 18h2M18 14v2M18 18v2" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </div>
    <div>
      <h2>Add New Product Batch</h2>
      <p>Fill in the details to generate QR codes</p>
    </div>
  </div>

  <!-- Body -->
  <div class="card-body-inner">
    <form action="/add-product" method="POST" enctype="multipart/form-data">

      <!-- Product Info -->
      <div class="form-section-label">Product Information</div>

      <div class="form-group">
        <label>Product Name</label>
        <input type="text" name="name" placeholder="e.g. Panadol Extra 500mg" required>
      </div>

      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" placeholder="e.g. Fast relief from headaches and migraines" required>
      </div>

      <div class="form-row-2">
        <div class="form-group">
          <label>Batch Number</label>
          <input type="text" name="batchNumber" placeholder="e.g. PAN-2025-001" required>
        </div>
        <div class="form-group">
          <label>Price(R.S)</label>
          <input type="number" name="price" placeholder="e.g. 7.99" step="0.01" required>
        </div>
      </div>

      <!-- Dates -->
      <div class="form-section-label">Dates & Stock</div>

      <div class="form-row-2">
        <div class="form-group">
          <label>Manufacturing Date</label>
          <input type="date" name="manufacturingDate" required>
        </div>
        <div class="form-group">
          <label>Expiry Date</label>
          <input type="date" name="expiryDate" required>
        </div>
      </div>

      <div class="form-row-2">
        <div class="form-group">
          <label>Quantity (Units)</label>
          <input type="number" name="quantity" placeholder="e.g. 500" required>
        </div>
        <div class="form-group">
          <label>Product Image</label>
          <input type="file" name="image" id="image" accept="image/*" required>
        </div>
      </div>

      <!-- Submit -->
      <button type="submit" class="btn-submit">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <rect x="3" y="3" width="7" height="7" rx="1" stroke="white" stroke-width="2"/>
          <rect x="14" y="3" width="7" height="7" rx="1" stroke="white" stroke-width="2"/>
          <rect x="3" y="14" width="7" height="7" rx="1" stroke="white" stroke-width="2"/>
          <path d="M14 14h2M14 18h2M18 14v2M18 18v2" stroke="white" stroke-width="2" stroke-linecap="round"/>
        </svg>
        Generate Products &amp; QR Codes
      </button>

    </form>
  </div>
</div>

<!-- FOOTER NOTE -->
<p class="footer-note">
  ← <a href="/">Back to Trust Layer Home</a>
</p>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>