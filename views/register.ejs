<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trust Layer — Sign Up</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Outfit:wght@200;300;400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --honey: #FA5716; /* Vibrant Orange */
      --amber: #0F5C5B; /* Deep Teal */
      --umber: #94A3B8; /* Muted Slate */
      --ink: #0F172A;
      --cream: #F8FAFC;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: #1B242C;
      background-image: radial-gradient(ellipse 80% 60% at 20% 80%, rgba(15, 92, 91, 0.35) 0%, transparent 70%), 
                        radial-gradient(ellipse 60% 50% at 80% 20%, rgba(250, 87, 22, 0.15) 0%, transparent 70%), 
                        linear-gradient(160deg, #1B242C 0%, #0F5C5B 40%, #1B242C 70%, #2a1a0e 100%);
      padding: 32px 16px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 32px;
    }

    .brand-icon {
      width: 34px;
      height: 34px;
      background: rgba(15, 92, 91, 0.2);
      border: 1.5px solid var(--honey);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .brand-name {
      font-size: 16px;
      font-weight: 500;
      color: #ffffff;
      letter-spacing: 0.03em;
      font-family: 'Outfit', sans-serif;
    }

    /* Gradient container form matching contact-form-card */
    .card {
      display: flex;
      align-items: stretch;
      flex-direction: column;
      gap: 16px;
      background-image: linear-gradient(45deg, #1B242C, #13191e);
      border-radius: 2em;
      padding: 45px 35px;
      width: 100%;
      max-width: 460px;
      box-sizing: border-box;
      position: relative;
      z-index: 1;
      margin: 0 auto;
      box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    .card::before {
      content: '';
      background-image: linear-gradient(45deg, var(--honey), var(--amber));
      position: absolute;
      top: -4px;
      left: -4px;
      right: -4px;
      bottom: -4px;
      z-index: -2;
      border-radius: 2.2em;
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 2px;
      text-align: center;
    }

    .card-sub {
      font-size: 11px;
      font-family: 'Outfit', sans-serif;
      color: #ffffff;
      text-align: center;
      margin-bottom: 16px;
      letter-spacing: 0.05em;
      line-height: 1.5;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      width: 100%;
      margin-bottom: 2px;
    }

    .field-label {
      font-size: 8px;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: rgba(243, 235, 217, 0.8) !important;
      font-weight: 500;
      display: block;
      margin-left: 4px;
      font-family: 'Outfit', sans-serif;
    }

    /* Styled input groups wrapper */
    .input-wrap {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid transparent;
      border-bottom: 1.5px solid var(--honey);
      outline: none;
      background-color: rgba(255, 255, 255, 0.02);
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      transition: all 0.2s ease;
      box-sizing: border-box;
      border-radius: 6px 6px 0 0;
      display: flex;
      align-items: center;
      height: 48px;
      position: relative;
    }

    .input-wrap:focus-within {
      background-color: rgba(255, 255, 255, 0.06);
      border-bottom: 1.5px solid var(--honey);
    }

    .input-wrap input {
      margin-left: 10px;
      background: transparent;
      border: none;
      color: #fff;
      width: 100%;
      height: 100%;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      outline: none;
    }

    .input-wrap input::placeholder {
      color: rgba(243, 235, 217, 0.5) !important;
    }

    /* make sure input form prefix icons look clean and readable */
    .input-wrap > svg.ico * {
      stroke: #ffffff !important;
      fill: none;
    }

    .eye-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: rgba(255, 255, 255, 0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      padding-right: 4px;
      transition: color 0.2s;
    }

    .eye-btn:hover {
      color: var(--honey);
    }

    .err {
      font-size: 10px;
      color: #f87171;
      margin-top: 2px;
      padding-left: 4px;
      display: none;
      font-family: 'Outfit', sans-serif;
    }

    .terms {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-top: 6px;
      margin-bottom: 12px;
      font-family: 'Outfit', sans-serif;
    }

    .terms input {
      width: 14px;
      height: 14px;
      accent-color: var(--honey);
      cursor: pointer;
      margin-top: 2px;
      flex-shrink: 0;
    }

    .terms span {
      font-size: 12px;
      color: rgba(243, 235, 217, 0.8);
      line-height: 1.5;
    }

    .terms a {
      color: var(--honey);
      text-decoration: none;
      font-weight: 500;
    }

    .terms a:hover {
      text-decoration: underline;
    }

    .signup-btn {
      margin-top: 6px;
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .25em;
      text-transform: uppercase;
      background: var(--honey);
      color: #ffffff;
      padding: 13px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid transparent;
      border-radius: 5em;
      overflow: hidden;
      transition: all 0.2s ease;
      cursor: pointer;
      width: 100%;
      box-sizing: border-box;
    }

    .signup-btn:hover {
      border: 2px solid var(--honey);
      background: transparent;
      color: var(--honey);
    }

    .signup-btn:active {
      transform: scale(0.98);
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 14px;
      margin-bottom: 14px;
    }

    .div-line {
      flex: 1;
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
    }

    .div-text {
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .login-row {
      text-align: center;
      font-family: 'Outfit', sans-serif;
    }

    .login-row a {
      font-size: 13px;
      color: #ffffff;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .login-row a:hover {
      color: var(--honey);
      text-decoration: underline;
    }

    .sec-note {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-top: 20px;
      padding: 12px 14px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
    }

    .sec-note span {
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.5;
    }

    .sec-note svg * {
      stroke: var(--honey) !important;
    }

    .success-msg {
      display: none;
      text-align: center;
      padding: 20px 0 4px;
    }

    .success-icon {
      width: 52px;
      height: 52px;
      background: rgba(15, 92, 91, 0.2);
      border: 2px solid var(--honey);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 14px;
    }

    .success-icon svg * {
      stroke: var(--honey) !important;
    }

    .success-title {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 600;
      color: #e8f5e8;
      margin-bottom: 6px;
    }

    .success-sub {
      font-family: 'Outfit', sans-serif;
      font-size: 12px;
      color: var(--umber);
      line-height: 1.7;
    }
  </style>
</head>

<body>



  <div class="card">

    <!-- FORM -->
    <div id="form-section">
      <div class="card-title">Create your account</div>
      <div class="card-sub">Start protecting your products in minutes — no credit card required</div>

      <!-- Brand Name -->
      <form action="/register" method="post" onsubmit="return handleSignup(event)">
        <div class="field">
          <label class="field-label" for="brandname">Brand name</label>
          <div class="input-wrap">
            <svg class="ico" width="15" height="15" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="3" width="12" height="10" rx="1.5" stroke="#3a6b3a" stroke-width="1.2" />
              <path d="M5 7h6M5 10h4" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            <input type="text" id="brandname" name="brandname" placeholder="e.g. Sidr Honey Co." required>
          </div>
          <div class="err" id="err-brand">Please enter your brand name.</div>
        </div>

        <!-- Email -->
        <div class="field">
          <label class="field-label" for="email">Email address</label>
          <div class="input-wrap">
            <svg class="ico" width="15" height="15" viewBox="0 0 16 16" fill="none">
              <rect x="1" y="3" width="14" height="10" rx="1.5" stroke="#3a6b3a" stroke-width="1.2" />
              <path d="M1 5l7 5 7-5" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
            <input type="email" id="email" name="email" placeholder="your@brand.pk" required>
          </div>
          <div class="err" id="err-email">Please enter a valid email address.</div>
        </div>

        <!-- Username -->
        <div class="field">
          <label class="field-label" for="username">Username</label>
          <div class="input-wrap">
            <svg class="ico" width="15" height="15" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="5" r="3" stroke="#3a6b3a" stroke-width="1.2" />
              <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            <input type="text" id="username" name="username" placeholder="Choose a username" required>
          </div>
          <div class="err" id="err-uname">Please enter a username.</div>
        </div>

        <!-- Password -->
        <div class="field">
          <label class="field-label" for="password">Password</label>
          <div class="input-wrap">
            <svg class="ico" width="15" height="15" viewBox="0 0 16 16" fill="none">
              <rect x="2" y="7" width="12" height="8" rx="1.5" stroke="#3a6b3a" stroke-width="1.2" />
              <path d="M5 7V5a3 3 0 016 0v2" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            <input type="password" id="password" name="password" placeholder="Min. 8 characters" required>
            <button class="eye-btn" onclick="togglePw()" type="button">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.2" />
                <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.2" />
              </svg>
            </button>
          </div>
          <div class="err" id="err-pw">Password must be at least 8 characters.</div>
        </div>

        <!-- Terms -->
        <div class="terms">
          <input type="checkbox" id="terms">
          <span>I agree to Trust Layer's <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></span>
        </div>
        <div class="err" id="err-terms" style="margin-top:-16px;margin-bottom:16px;">Please accept the terms to
          continue.</div>

        <button class="signup-btn" type="submit">Create my account ↗</button>
      </form>
      <div class="divider">
        <div class="div-line"></div>
        <span class="div-text">already have an account?</span>
        <div class="div-line"></div>
      </div>

      <div class="login-row">
        <a href="/login">Sign in instead →</a>
      </div>


    </div>

    <!-- SUCCESS STATE -->
    <div class="success-msg" id="success-section">
      <div class="success-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M5 12l5 5L19 7" stroke="#4caf50" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="success-title">Account created!</div>
      <div class="success-sub" id="success-sub">Welcome to Trust Layer.<br>Redirecting you to your dashboard...</div>
    </div>

  </div>

  <script>
    function togglePw() {
      var inp = document.getElementById('password');
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }

    function handleSignup(event) {
      var brand = document.getElementById('brandname').value.trim();
      var email = document.getElementById('email').value.trim();
      var uname = document.getElementById('username').value.trim();
      var pw = document.getElementById('password').value.trim();
      var terms = document.getElementById('terms').checked;

      var eb = document.getElementById('err-brand');
      var ee = document.getElementById('err-email');
      var eu = document.getElementById('err-uname');
      var ep = document.getElementById('err-pw');
      var et = document.getElementById('err-terms');

      eb.style.display = 'none';
      ee.style.display = 'none';
      eu.style.display = 'none';
      ep.style.display = 'none';
      et.style.display = 'none';

      var ok = true;
      if (!brand) { eb.style.display = 'block'; ok = false; }
      if (!email || !email.includes('@')) { ee.style.display = 'block'; ok = false; }
      if (!uname) { eu.style.display = 'block'; ok = false; }
      if (pw.length < 8) { ep.style.display = 'block'; ok = false; }
      if (!terms) { et.style.display = 'block'; ok = false; }

      if (!ok) {
        event.preventDefault();
      }
      return ok;
    }
  </script>

</body>

</html>