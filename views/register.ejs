<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trust Layer — Sign Up</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Outfit:wght@200;300;400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --honey: #FA5716;
      --amber: #0F5C5B;
      --ink: #0F172A;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #0F172A;
      background-image:
        radial-gradient(ellipse 80% 60% at 20% 80%, rgba(15, 92, 91, 0.3) 0%, transparent 70%),
        radial-gradient(ellipse 60% 50% at 80% 20%, rgba(250, 87, 22, 0.12) 0%, transparent 70%),
        linear-gradient(160deg, #0F172A 0%, #0d3d3c 50%, #0F172A 100%);
      padding: 20px;
      font-family: 'Outfit', sans-serif;
    }

    /* ── CARD ── */
    .card {
      width: 100%;
      max-width: 440px;
      background: #1E293B;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 24px;
      padding: 44px 36px 36px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--amber), var(--honey), var(--amber));
    }

    /* ── SHIELD ── */
    .shield-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 24px;
    }

    .shield-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: rgba(250, 87, 22, 0.1);
      border: 1px solid rgba(250, 87, 22, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: glow 2.5s ease-in-out infinite;
    }

    @keyframes glow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(250, 87, 22, 0.15); }
      50% { box-shadow: 0 0 0 10px rgba(250, 87, 22, 0); }
    }

    /* ── HEADINGS ── */
    .eyebrow {
      text-align: center;
      font-size: 10px;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--honey);
      font-weight: 600;
      margin-bottom: 8px;
    }

    .title {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 600;
      color: #F1F5F9;
      text-align: center;
      margin-bottom: 8px;
    }

    .subtitle {
      font-size: 13px;
      color: #94A3B8;
      text-align: center;
      line-height: 1.6;
      margin-bottom: 28px;
    }

    /* ── ERROR BANNER ── */
    .error-banner {
      display: none;
      padding: 12px 16px;
      border-radius: 10px;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #FCA5A5;
      font-size: 13px;
      font-weight: 500;
      text-align: center;
      margin-bottom: 20px;
      animation: shakeIn .4s ease;
    }

    @keyframes shakeIn {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      50% { transform: translateX(5px); }
      75% { transform: translateX(-3px); }
    }

    /* ── FORM FIELDS ── */
    .field {
      margin-bottom: 20px;
    }

    .field label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: #CBD5E1;
      margin-bottom: 8px;
    }

    .input-wrap {
      display: flex;
      align-items: center;
      background: #0F172A;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 0 16px;
      height: 50px;
      transition: border-color 0.25s, box-shadow 0.25s;
    }

    .input-wrap:focus-within {
      border-color: var(--amber);
      box-shadow: 0 0 0 3px rgba(15, 92, 91, 0.15);
    }

    .input-wrap svg {
      flex-shrink: 0;
      margin-right: 12px;
    }

    .input-wrap input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: #F1F5F9;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 400;
      height: 100%;
    }

    .input-wrap input::placeholder {
      color: #64748B;
    }

    /* Override browser autofill background */
    .input-wrap input:-webkit-autofill,
    .input-wrap input:-webkit-autofill:hover,
    .input-wrap input:-webkit-autofill:focus,
    .input-wrap input:-webkit-autofill:active {
      -webkit-box-shadow: 0 0 0 30px #0F172A inset !important;
      -webkit-text-fill-color: #F1F5F9 !important;
      transition: background-color 5000s ease-in-out 0s;
    }

    .eye-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: #64748B;
      display: flex;
      align-items: center;
      padding: 4px;
      transition: color 0.2s;
    }

    .eye-btn:hover { color: var(--amber); }

    /* ── TERMS ── */
    .flex-row {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      margin-bottom: 24px;
    }

    .checkbox-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }

    .checkbox-wrap input {
      accent-color: var(--honey);
      width: 14px;
      height: 14px;
      cursor: pointer;
    }

    .checkbox-wrap span {
      font-size: 12px;
      color: #FFFFFF;
      cursor: pointer;
    }

    .checkbox-wrap a {
      color: var(--amber);
      text-decoration: none;
    }

    .checkbox-wrap a:hover {
      text-decoration: underline;
    }

    /* ── SUBMIT BUTTON ── */
    .btn-submit {
      width: 100%;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: var(--honey);
      color: #FFFFFF;
      border: none;
      border-radius: 12px;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .15em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.25s, transform 0.15s, box-shadow 0.25s;
    }

    .btn-submit:hover {
      background: #e04c10;
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(250, 87, 22, 0.3);
    }

    .btn-submit:active {
      transform: translateY(0);
      box-shadow: none;
    }

    /* ── BACK LINK ── */
    .back-link {
      text-align: center;
      margin-top: 24px;
    }

    .back-link a {
      font-size: 13px;
      color: #64748B;
      text-decoration: none;
      transition: color 0.2s;
    }

    .back-link a:hover { color: #F1F5F9; }

    /* ── SUCCESS STATE ── */
    .success-msg {
      display: none;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .success-icon {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: rgba(76, 175, 80, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 24px;
    }

    .success-title {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 600;
      color: #F1F5F9;
      margin-bottom: 8px;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 480px) {
      .card {
        padding: 36px 24px 28px;
        border-radius: 18px;
      }
      .title { font-size: 22px; }
      .subtitle { font-size: 12px; }
    }
  </style>
</head>

<body>

  <div class="card">

    <div id="form-section">
      <!-- Shield -->
      <div class="shield-wrap">
        <div class="shield-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#FA5716" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 8v4M12 16h.01" stroke="#FA5716" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Headings -->
      <div class="eyebrow">Trust Layer</div>
      <h1 class="title">Brand Registration</h1>
      <p class="subtitle">Create a new brand space. No credit card required.</p>

      <!-- Error -->
      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="error-banner" id="errorBanner" style="display: block;">
        <span id="errorText"><%= error %></span>
      </div>
      <% } %>

      <div class="error-banner" id="jsErrorBanner" style="display: none;">
        <span id="jsErrorText">Please fill in all fields correctly.</span>
      </div>

      <!-- Form -->
      <form id="registerForm" method="POST" action="/register" onsubmit="return handleSignup(event)">

        <!-- Brand Name -->
        <div class="field">
          <label for="brandname">Brand Name</label>
          <div class="input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M3 21h18M5 21V7l8-4 8 4v14M9 21v-4h6v4" stroke="#64748B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <input type="text" id="brandname" name="brandname" placeholder="e.g. Sidr Honey Co." required autocomplete="organization">
          </div>
        </div>

        <!-- Email -->
        <div class="field">
          <label for="email">Email Address</label>
          <div class="input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke="#64748B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <input type="email" id="email" name="email" placeholder="your@brand.com" required autocomplete="email">
          </div>
        </div>

        <!-- Username -->
        <div class="field">
          <label for="username">Username</label>
          <div class="input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="#64748B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="7" r="4" stroke="#64748B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <input type="text" id="username" name="username" placeholder="Choose a username" required autocomplete="username">
          </div>
        </div>

        <!-- Password -->
        <div class="field">
          <label for="password">Password</label>
          <div class="input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <rect x="3" y="11" width="18" height="11" rx="2" stroke="#64748B" stroke-width="1.5"/>
              <path d="M7 11V7a5 5 0 0110 0v4" stroke="#64748B" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <input type="password" id="password" name="password" placeholder="Min. 8 characters" required autocomplete="new-password">
            <button class="eye-btn" type="button" onclick="togglePw()" aria-label="Toggle password">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Terms -->
        <div class="flex-row" style="margin-bottom: 20px;">
          <label class="checkbox-wrap">
            <input type="checkbox" id="terms" required>
            <span>I agree to Trust Layer's <a href="#">Terms of Service</a></span>
          </label>
        </div>

        <!-- Submit -->
        <button class="btn-submit" type="submit" id="submitBtn">
          Create Account
        </button>
      </form>

      <!-- Back -->
      <div class="back-link">
        <a href="/login">&larr; Back to Login</a>
      </div>
    </div>

    <!-- SUCCESS STATE -->
    <div class="success-msg" id="success-section">
      <div class="success-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
          <path d="M5 12l5 5L19 7" stroke="#4caf50" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="success-title">Account Created!</div>
      <div class="subtitle" id="success-sub">Welcome to Trust Layer.<br>Redirecting you to your dashboard...</div>
    </div>

  </div>

  <script>
    function togglePw() {
      var inp = document.getElementById('password');
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }

    function handleSignup(event) {
      var bn = document.getElementById('brandname').value.trim();
      var em = document.getElementById('email').value.trim();
      var u = document.getElementById('username').value.trim();
      var p = document.getElementById('password').value.trim();
      var t = document.getElementById('terms').checked;
      var errBox = document.getElementById('jsErrorBanner');
      var errText = document.getElementById('jsErrorText');
      
      if (!bn || !em || !u || !p || !t) {
        errText.innerText = 'Please fill in all fields and accept the terms.';
        errBox.style.display = 'block';
        event.preventDefault();
        return false;
      }
      if (p.length < 8) {
        errText.innerText = 'Password must be at least 8 characters.';
        errBox.style.display = 'block';
        event.preventDefault();
        return false;
      }
      
      errBox.style.display = 'none';
      
      // Allow form submission to proceed natively to /register. 
      // If server returns success, we could handle it via AJAX to show success section,
      // but standard form POST handles redirection natively.
      return true;
    }
  </script>

</body>

</html>