  <script>
    function toggleMenu() {
      document.getElementById('mobileMenu').classList.toggle('open');
    }
    document.addEventListener('click', function (e) {
      const menu = document.getElementById('mobileMenu');
      const hamburger = document.getElementById('hamburger');
      if (!menu.contains(e.target) && !hamburger.contains(e.target)) {
        menu.classList.remove('open');
      }
    });
    (function () {
      const contactLink = document.querySelector('.nav-links a[href="#contact"]');
      if (!contactLink) return;

      const section = document.getElementById('contact');

      const observer = new IntersectionObserver(
        ([entry]) => {
          // remove active from all nav links first
          document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
          if (entry.isIntersecting) {
            contactLink.classList.add('active');
          }
        },
        { threshold: 0.15, rootMargin: '-72px 0px 0px 0px' }
      );

      observer.observe(section);
    })();


    function openVideo() {
      const modal = document.getElementById('videoModal');
      modal.style.display = 'flex';
      document.getElementById('myVideo').play();
    }
    function closeVideo() {
      const modal = document.getElementById('videoModal');
      modal.style.display = 'none';
      document.getElementById('myVideo').pause();
    }
    // Close on background click
    document.getElementById('videoModal').addEventListener('click', function (e) {
      if (e.target === this) closeVideo();
    });
    // Spotlight Navbar Logic
    const navLinksList = document.querySelector('.nav-links');
    const hoverPill = document.createElement('div');
    hoverPill.className = 'nav-hover-pill';

    if (navLinksList) {
      navLinksList.appendChild(hoverPill);

      const links = navLinksList.querySelectorAll('li');
      links.forEach(li => {
        li.addEventListener('mouseenter', (e) => {
          const left = li.offsetLeft;
          const width = li.offsetWidth;
          hoverPill.style.opacity = '1';
          hoverPill.style.left = `${left}px`;
          hoverPill.style.width = `${width}px`;
        });
      });

      navLinksList.addEventListener('mouseleave', () => {
        const activeLink = navLinksList.querySelector('a.active');
        if (activeLink) {
          const li = activeLink.parentElement;
          hoverPill.style.left = `${li.offsetLeft}px`;
          hoverPill.style.width = `${li.offsetWidth}px`;
          hoverPill.style.opacity = '1';
        } else {
          hoverPill.style.opacity = '0';
        }
      });

      // Initialize pill on active link if any
      setTimeout(() => {
        const activeLink = navLinksList.querySelector('a.active');
        if (activeLink) {
          const li = activeLink.parentElement;
          hoverPill.style.opacity = '1';
          hoverPill.style.left = `${li.offsetLeft}px`;
          hoverPill.style.width = `${li.offsetWidth}px`;
        }
      }, 100);
    }
  </script>

