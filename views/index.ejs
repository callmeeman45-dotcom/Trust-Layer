<script>
  function selectProduct(n) {
    document.getElementById('p1').classList.remove('active');
    document.getElementById('p2').classList.remove('active');
    document.getElementById('p' + n).classList.add('active');
    if (n === 1) {
      document.getElementById('scanStatus').textContent = 'First scan · Authentic';
      document.getElementById('scanBadge').textContent = '✔ Verified';
      document.getElementById('scanBadge').style.color = '#8A7650';
      document.getElementById('scanBadge').style.borderColor = '#8A7650';
    } else {
      document.getElementById('scanStatus').textContent = 'Second scan · Duplicate alert';
      document.getElementById('scanBadge').textContent = '⚠ Check product';
      document.getElementById('scanBadge').style.color = '#f0a020';
      document.getElementById('scanBadge').style.borderColor = '#8a5c00';
    }
  }

  function toggleMenu() {
    const menu = document.getElementById('mobileMenu');
    const hamburger = document.getElementById('hamburger');
    menu.classList.toggle('open');
    hamburger.classList.toggle('active');
  }

  // Close menu on outside click
  document.addEventListener('click', function(e) {
    const menu = document.getElementById('mobileMenu');
    const hamburger = document.getElementById('hamburger');
    if (!menu.contains(e.target) && !hamburger.contains(e.target)) {
      menu.classList.remove('open');
      hamburger.classList.remove('active');
    }
  });
</script>

