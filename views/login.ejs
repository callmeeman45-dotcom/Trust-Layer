<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trust Layer — Login</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Outfit:wght@200;300;400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --honey: #FA5716; /* Vibrant Orange */
      --amber: #0F5C5B; /* Deep Teal */
      --umber: #94A3B8; /* Muted Slate */
      --ink: #0F172A;
      --cream: #F8FAFC;
    }

    /* Reset and page base styling */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: #1B242C;
      background-image: radial-gradient(ellipse 80% 60% at 20% 80%, rgba(15, 92, 91, 0.35) 0%, transparent 70%), 
                        radial-gradient(ellipse 60% 50% at 80% 20%, rgba(250, 87, 22, 0.15) 0%, transparent 70%), 
                        linear-gradient(160deg, #1B242C 0%, #0F5C5B 40%, #1B242C 70%, #2a1a0e 100%);
      padding: 20px;
    }

    /* Gradient container form matching contact-form-card */
    .form {
      display: flex;
      align-items: stretch;
      flex-direction: column;
      gap: 16px;
      background-image: linear-gradient(45deg, #1B242C, #13191e);
      border-radius: 2em;
      padding: 45px 35px;
      width: 100%;
      max-width: 460px;
      box-sizing: border-box;
      position: relative;
      z-index: 1;
      margin: 0 auto;
      box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    .form::before {
      content: '';
      background-image: linear-gradient(45deg, var(--honey), var(--amber));
      position: absolute;
      top: -4px;
      left: -4px;
      right: -4px;
      bottom: -4px;
      z-index: -2;
      border-radius: 2.2em;
    }

    .form-title {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 600;
      color: #fff;
      margin-bottom: 2px;
      text-align: center;
    }

    .form-sub {
      font-size: 11px;
      font-family: 'Outfit', sans-serif;
      color: #ffffff;
      text-align: center;
      margin-bottom: 16px;
      letter-spacing: 0.05em;
    }

    .flex-column {
      display: flex;
      flex-direction: column;
      gap: 6px;
      width: 100%;
    }

    .flex-column > label {
      font-size: 8px;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: rgba(243, 235, 217, 0.8) !important;
      font-weight: 500;
      display: block;
      margin-left: 4px;
      font-family: 'Outfit', sans-serif;
    }

    /* Styled input groups wrapper */
    .inputForm {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid transparent;
      border-bottom: 1.5px solid var(--honey);
      outline: none;
      background-color: rgba(255, 255, 255, 0.02);
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      transition: all 0.2s ease;
      box-sizing: border-box;
      border-radius: 6px 6px 0 0;
      display: flex;
      align-items: center;
      height: 48px;
    }

    .inputForm:focus-within {
      background-color: rgba(255, 255, 255, 0.06);
      border-bottom: 1.5px solid var(--honey);
    }

    .input {
      margin-left: 10px;
      background: transparent;
      border: none;
      color: #fff;
      width: 100%;
      height: 100%;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      outline: none;
    }

    .input::placeholder {
      color: rgba(243, 235, 217, 0.5) !important;
    }

    .err {
      font-size: 10px;
      color: #f87171;
      margin-top: 2px;
      padding-left: 4px;
      display: none;
      font-family: 'Outfit', sans-serif;
    }

    .flex-row {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 10px;
      justify-content: space-between;
      font-family: 'Outfit', sans-serif;
      margin-top: 4px;
    }

    .forgot-link {
      font-size: 12px;
      color: rgba(243, 235, 217, 0.8);
      background: none;
      border: none;
      cursor: pointer;
      text-decoration: underline;
      font-family: inherit;
    }

    .forgot-link:hover {
      color: var(--honey);
    }

    /* make sure input form prefix icons look clean and readable */
    .inputForm > svg * {
      stroke: #ffffff !important;
    }

    .eye-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: rgba(255, 255, 255, 0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      padding-right: 4px;
      transition: color 0.2s;
    }

    .eye-btn:hover {
      color: var(--honey);
    }

    .button-submit {
      margin-top: 12px;
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .25em;
      text-transform: uppercase;
      background: var(--honey);
      color: #ffffff;
      padding: 13px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid transparent;
      border-radius: 5em;
      overflow: hidden;
      transition: all 0.2s ease;
      cursor: pointer;
      width: 100%;
      box-sizing: border-box;
    }

    .button-submit:hover {
      border: 2px solid var(--honey);
      background: transparent;
      color: var(--honey);
    }

    .button-submit:active {
      transform: scale(0.98);
    }

    .p {
      text-align: center;
      color: rgba(255, 255, 255, 0.6);
      font-size: 13px;
      margin: 15px 0 5px 0;
      font-family: 'Outfit', sans-serif;
    }

    .span {
      font-size: 13px;
      margin-left: 5px;
      color: var(--honey);
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
    }

    .span:hover {
      text-decoration: underline;
    }

    .nostyling {
      color: inherit;
      text-decoration: none;
    }

    /* ── UIVERSE CREATIVE BUTTON (Li-Deheng) ── */
    .btn-create-acc {
      --main-size: 11px;
      --color-text: #ffffff;
      --color-background: var(--honey);
      --color-background-hover: #ff7034;
      --color-outline: rgba(250, 87, 22, 0.25);
      --color-shadow: rgba(0, 0, 0, 0.3);
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
      text-decoration: none;
      border: none;
      border-radius: 100em;
      padding: 12px 12px 12px 20px;
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: var(--main-size);
      color: var(--color-text);
      background: var(--color-background);
      box-shadow: 0 0 0.2em 0 var(--color-background);
      transition: 1s;
      margin-top: 10px;
      box-sizing: border-box;
      letter-spacing: .05em;
      text-transform: uppercase;
      width: 100%;
    }

    .btn-create-acc:active {
      transform: scale(0.95);
    }

    .btn-create-acc:hover {
      outline: 0.1em solid transparent;
      outline-offset: 0.2em;
      box-shadow: 0 0 1em 0 var(--color-background);
      animation:
        ripple 1s linear infinite,
        colorize 1s infinite;
      transition: 0.5s;
    }

    .btn-create-acc span {
      margin-right: 0.3em;
      transition: 0.5s;
      color: #ffffff !important;
    }

    .btn-create-acc:hover span {
      text-shadow: 5px 5px 5px var(--color-shadow);
      color: #ffffff !important;
    }

    .btn-create-acc:active span {
      text-shadow: none;
    }

    .btn-create-acc svg {
      height: 1.1em;
      fill: var(--color-text);
      margin-right: -0.16em;
      position: relative;
      transition: 0.5s;
    }

    .btn-create-acc:hover svg {
      margin-right: 0.66em;
      transition: 0.5s;
      filter: drop-shadow(5px 5px 2.5px var(--color-shadow));
    }

    .btn-create-acc:active svg {
      filter: none;
    }

    .btn-create-acc svg polygon {
      fill: var(--color-text) !important;
      stroke: none !important;
    }

    .btn-create-acc svg polygon:nth-child(1) {
      transition: 0.4s;
      transform: translateX(-60%);
    }

    .btn-create-acc svg polygon:nth-child(2) {
      transition: 0.5s;
      transform: translateX(-30%);
    }

    .btn-create-acc:hover svg polygon:nth-child(1) {
      transform: translateX(0%);
      animation: opacity 1s infinite 0.6s;
    }

    .btn-create-acc:hover svg polygon:nth-child(2) {
      transform: translateX(0%);
      animation: opacity 1s infinite 0.4s;
    }

    .btn-create-acc:hover svg polygon:nth-child(3) {
      animation: opacity 1s infinite 0.2s;
    }

    @keyframes opacity {
      0% {
        opacity: 1;
      }
      50% {
        opacity: 0;
      }
      100% {
        opacity: 1;
      }
    }

    @keyframes colorize {
      0% {
        background: var(--color-background);
      }
      50% {
        background: var(--color-background-hover);
      }
      100% {
        background: var(--color-background);
      }
    }

    @keyframes ripple {
      0% {
        outline: 0em solid transparent;
        outline-offset: -0.1em;
      }
      50% {
        outline: 0.2em solid var(--color-outline);
        outline-offset: 0.2em;
      }
      100% {
        outline: 0.4em solid transparent;
        outline-offset: 0.4em;
      }
    }
  </style>
</head>

<body>

  <form class="form" action="/login" method="post" onsubmit="return handleLogin(event)">
    <div class="form-title">Welcome Back</div>
    <div class="form-sub">Sign in to your brand protection space</div>

    <!-- Username field -->
    <div class="flex-column">
      <label for="username">Username</label>
      <div class="inputForm">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="5" r="3" stroke="#64748b" stroke-width="1.2" />
          <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#64748b" stroke-width="1.2" stroke-linecap="round" />
        </svg>
        <input type="text" class="input" id="username" name="username" placeholder="Enter your username" required>
      </div>
      <div class="err" id="err-u">Please enter your username.</div>
    </div>

    <!-- Password field -->
    <div class="flex-column">
      <label for="password">Password</label>
      <div class="inputForm">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
          <rect x="2" y="7" width="12" height="8" rx="1.5" stroke="#64748b" stroke-width="1.2" />
          <path d="M5 7V5a3 3 0 016 0v2" stroke="#64748b" stroke-width="1.2" stroke-linecap="round" />
        </svg>
        <input type="password" class="input" id="password" name="password" placeholder="Enter your password" required>
        <button class="eye-btn" onclick="togglePw()" type="button" aria-label="Toggle password visibility">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.2" />
            <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.2" />
          </svg>
        </button>
      </div>
      <div class="err" id="err-p">Please enter your password.</div>
    </div>

    <!-- Remember & Forgot -->
    <div class="flex-row">
      <div style="display: flex; align-items: center; gap: 8px;">
        <input type="checkbox" id="rem">
        <label for="rem" style="font-size: 13px; color: rgba(243, 235, 217, 0.8); font-weight: 400; cursor: pointer;">Keep me signed in</label>
      </div>
      <button class="forgot-link" type="button" onclick="alert('Password reset link sent to your email.')">Forgot password?</button>
    </div>

    <!-- Submit -->
    <button class="button-submit" type="submit">Sign In</button>
  </form>

  <script>
    function togglePw() {
      var inp = document.getElementById('password');
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }

    function handleLogin(event) {
      var u = document.getElementById('username').value.trim();
      var p = document.getElementById('password').value.trim();
      var eu = document.getElementById('err-u');
      var ep = document.getElementById('err-p');
      eu.style.display = 'none';
      ep.style.display = 'none';
      var ok = true;
      if (!u) { eu.style.display = 'block'; ok = false; }
      if (!p) { ep.style.display = 'block'; ok = false; }
      if (!ok) {
        event.preventDefault();
      }
      return ok;
    }
  </script>

</body>

</html>