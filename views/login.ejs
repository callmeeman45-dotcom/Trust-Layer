<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trust Layer — Login</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Outfit:wght@200;300;400;500;600&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --honey: #FA5716;
      --amber: #0F5C5B;
      --ink: #0F172A;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #0F172A;
      background-image:
        radial-gradient(ellipse 80% 60% at 20% 80%, rgba(15, 92, 91, 0.3) 0%, transparent 70%),
        radial-gradient(ellipse 60% 50% at 80% 20%, rgba(250, 87, 22, 0.12) 0%, transparent 70%),
        linear-gradient(160deg, #0F172A 0%, #0d3d3c 50%, #0F172A 100%);
      padding: 20px;
      font-family: 'Outfit', sans-serif;
    }

    /* ── CARD ── */
    .card {
      width: 100%;
      max-width: 440px;
      background: #1E293B;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 24px;
      padding: 44px 36px 36px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--amber), var(--honey), var(--amber));
    }

    /* ── SHIELD ── */
    .shield-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 24px;
    }

    .shield-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: rgba(250, 87, 22, 0.1);
      border: 1px solid rgba(250, 87, 22, 0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: glow 2.5s ease-in-out infinite;
    }

    @keyframes glow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(250, 87, 22, 0.15); }
      50% { box-shadow: 0 0 0 10px rgba(250, 87, 22, 0); }
    }

    /* ── HEADINGS ── */
    .eyebrow {
      text-align: center;
      font-size: 10px;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: var(--honey);
      font-weight: 600;
      margin-bottom: 8px;
    }

    .title {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 600;
      color: #F1F5F9;
      text-align: center;
      margin-bottom: 8px;
    }

    .subtitle {
      font-size: 13px;
      color: #94A3B8;
      text-align: center;
      line-height: 1.6;
      margin-bottom: 28px;
    }

    /* ── ERROR BANNER ── */
    .error-banner {
      display: none;
      padding: 12px 16px;
      border-radius: 10px;
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #FCA5A5;
      font-size: 13px;
      font-weight: 500;
      text-align: center;
      margin-bottom: 20px;
      animation: shakeIn .4s ease;
    }

    @keyframes shakeIn {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      50% { transform: translateX(5px); }
      75% { transform: translateX(-3px); }
    }

    /* ── FORM FIELDS ── */
    .field {
      margin-bottom: 20px;
    }

    .field label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: #CBD5E1;
      margin-bottom: 8px;
    }

    .input-wrap {
      display: flex;
      align-items: center;
      background: #0F172A;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 0 16px;
      height: 50px;
      transition: border-color 0.25s, box-shadow 0.25s;
    }

    .input-wrap:focus-within {
      border-color: var(--amber);
      box-shadow: 0 0 0 3px rgba(15, 92, 91, 0.15);
    }

    .input-wrap svg {
      flex-shrink: 0;
      margin-right: 12px;
    }

    .input-wrap input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: #F1F5F9;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      font-weight: 400;
      height: 100%;
    }

    .input-wrap input::placeholder {
      color: #64748B;
    }

    /* Override browser autofill background */
    .input-wrap input:-webkit-autofill,
    .input-wrap input:-webkit-autofill:hover,
    .input-wrap input:-webkit-autofill:focus,
    .input-wrap input:-webkit-autofill:active {
      -webkit-box-shadow: 0 0 0 30px #0F172A inset !important;
      -webkit-text-fill-color: #F1F5F9 !important;
      transition: background-color 5000s ease-in-out 0s;
    }

    .eye-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: #64748B;
      display: flex;
      align-items: center;
      padding: 4px;
      transition: color 0.2s;
    }

    .eye-btn:hover { color: var(--amber); }

    /* ── REMEMBER & FORGOT ── */
    .flex-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }

    .checkbox-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }

    .checkbox-wrap input {
      accent-color: var(--honey);
      width: 14px;
      height: 14px;
      cursor: pointer;
    }

    .checkbox-wrap span {
      font-size: 12px;
      color: #FFFFFF;
      cursor: pointer;
    }

    .forgot-link {
      font-size: 12px;
      color: #94A3B8;
      text-decoration: none;
      transition: color 0.2s;
      background: none;
      border: none;
      cursor: pointer;
      font-family: inherit;
    }

    .forgot-link:hover {
      color: #F1F5F9;
    }

    /* ── SUBMIT BUTTON ── */
    .btn-submit {
      width: 100%;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: var(--honey);
      color: #FFFFFF;
      border: none;
      border-radius: 12px;
      font-family: 'Outfit', sans-serif;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .15em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.25s, transform 0.15s, box-shadow 0.25s;
    }

    .btn-submit:hover {
      background: #e04c10;
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(250, 87, 22, 0.3);
    }

    .btn-submit:active {
      transform: translateY(0);
      box-shadow: none;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 480px) {
      .card {
        padding: 36px 24px 28px;
        border-radius: 18px;
      }
      .title { font-size: 22px; }
      .subtitle { font-size: 12px; }
    }
  </style>
</head>

<body>

  <div class="card">

    <!-- Top Accent handled by ::before -->

    <!-- Shield -->
    <div class="shield-wrap">
      <div class="shield-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#FA5716" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M9 12l2 2 4-4" stroke="#FA5716" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    <!-- Headings -->
    <div class="eyebrow">Trust Layer</div>
    <h1 class="title">Brand Portal</h1>
    <p class="subtitle">Sign in to your brand protection space to manage registries and products.</p>

    <!-- Error -->
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="error-banner" id="errorBanner" style="display: block;">
      <span id="errorText"><%= error %></span>
    </div>
    <script>
      // Force clear fields after a slight delay to override browser password managers
      window.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
          document.getElementById('username').value = '';
          document.getElementById('password').value = '';
        }, 50);
      });
    </script>
    <% } %>

    <div class="error-banner" id="jsErrorBanner" style="display: none;">
      <span id="jsErrorText">Please fill in all fields.</span>
    </div>

    <!-- Form -->
    <form id="loginForm" method="POST" action="/login" onsubmit="return handleLogin(event)">

      <!-- Username -->
      <div class="field">
        <label for="username">Username</label>
        <div class="input-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="#64748B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="7" r="4" stroke="#64748B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <input type="text" id="username" name="username" placeholder="Enter your username" required autocomplete="username">
        </div>
      </div>

      <!-- Password -->
      <div class="field">
        <label for="password">Password</label>
        <div class="input-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="11" width="18" height="11" rx="2" stroke="#64748B" stroke-width="1.5"/>
            <path d="M7 11V7a5 5 0 0110 0v4" stroke="#64748B" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input type="password" id="password" name="password" placeholder="Enter your password" required autocomplete="current-password">
          <button class="eye-btn" type="button" onclick="togglePw()" aria-label="Toggle password">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Remember & Forgot -->
      <div class="flex-row">
        <label class="checkbox-wrap">
          <input type="checkbox" id="rem">
          <span>Keep me signed in</span>
        </label>
        <button class="forgot-link" type="button" onclick="alert('Password reset link sent to your email.')">Forgot password?</button>
      </div>

      <!-- Submit -->
      <button class="btn-submit" type="submit" id="submitBtn">
        Sign In
      </button>
    </form>

  </div>

  <script>
    function togglePw() {
      var inp = document.getElementById('password');
      inp.type = inp.type === 'password' ? 'text' : 'password';
    }

    function handleLogin(event) {
      var u = document.getElementById('username').value.trim();
      var p = document.getElementById('password').value.trim();
      var errBox = document.getElementById('jsErrorBanner');
      
      if (!u || !p) {
        errBox.style.display = 'block';
        event.preventDefault();
        return false;
      }
      errBox.style.display = 'none';
      return true;
    }
  </script>

</body>

</html>