<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Scan Dashboard</title>
  <link rel="stylesheet" href="/css/dashboard-layout.css">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

  <style>
    :root {
      --honey: #FA5716; /* Vibrant Orange */
      --amber: #0F5C5B; /* Deep Teal */
      --umber: #94A3B8; /* Muted Slate */
      --ink: #0F172A;
      --cream: #F8FAFC;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--cream);
      color: var(--ink);
      min-height: 100vh;
    }

    /* ── PAGE HEADER / TOP ROW ── */
    .dashboard-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 16px;
      flex-shrink: 0;
    }

    .page-tag {
      font-size: 8px;
      letter-spacing: .4em;
      text-transform: uppercase;
      color: var(--honey);
      font-weight: 300;
      margin-bottom: 6px;
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 600;
      color: var(--ink);
    }

    /* ── STATS CARDS ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 12px;
      width: 100%;
      flex-shrink: 0;
    }

    .stat-card {
      background: #ffffff;
      border: 1.5px solid rgba(15, 92, 91, 0.08);
      border-radius: 18px;
      padding: 24px;
      position: relative;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 30px rgba(15, 92, 91, 0.05);
    }

    /* Accent lines on top of cards */
    .stat-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--kpi-color, var(--umber));
    }

    .stat-card .stat-num {
      font-size: 36px;
      font-weight: 700;
      color: var(--kpi-text-color, var(--ink));
      line-height: 1;
      margin-bottom: 8px;
    }

    .stat-card .stat-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--umber);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .stat-card .stat-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--kpi-color, var(--umber));
    }

    /* ── TABLE CARD ── */
    .table-card {
      background: #ffffff;
      border: 1.5px solid rgba(15, 92, 91, 0.08);
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
      overflow: hidden;
      margin-bottom: 40px;
      flex-shrink: 0;
    }

    .table-card-header {
      padding: 28px 32px;
      border-bottom: 1.5px solid #f1f5f9;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 20px;
    }

    .table-card-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 600;
      color: var(--ink);
    }

    .table-card-header p {
      font-size: 12px;
      color: var(--umber);
      margin-top: 2px;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    /* Search input */
    .search-wrap {
      position: relative;
    }

    .search-wrap input {
      padding: 10px 14px 10px 38px;
      border: 1.5px solid #e2e8f0;
      border-radius: 30px;
      font-size: 12px;
      font-family: 'Outfit', sans-serif;
      color: var(--ink);
      background: #f8fafc;
      width: 240px;
      transition: all 0.25s ease;
      outline: none;
    }

    .search-wrap input:focus {
      border-color: var(--honey);
      background: #ffffff;
      box-shadow: 0 0 0 3px rgba(250, 87, 22, 0.08);
    }

    .search-wrap svg {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
    }

    /* Action buttons */
    .btn-export {
      padding: 10px 20px;
      background: var(--amber);
      color: #ffffff;
      border: none;
      border-radius: 30px;
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.25s ease;
    }

    .btn-export:hover {
      background: #0d4e4d;
      box-shadow: 0 5px 15px rgba(15, 92, 91, 0.15);
    }

    .btn-analytics {
      padding: 8px 20px;
      background: transparent;
      border: 2px solid var(--honey);
      color: var(--honey);
      border-radius: 30px;
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      transition: all 0.25s ease;
    }

    .btn-analytics:hover {
      background: var(--honey);
      color: #ffffff;
      box-shadow: 0 5px 15px rgba(250, 87, 22, 0.15);
    }

    /* Table styles */
    .table-wrap {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead tr {
      background: #f8fafc;
      border-bottom: 1.5px solid #e2e8f0;
    }

    thead th {
      padding: 16px 24px;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--umber);
      white-space: nowrap;
      text-align: left;
    }

    tbody tr {
      border-bottom: 1px solid #f1f5f9;
      transition: background 0.2s ease;
    }

    tbody tr:last-child {
      border-bottom: none;
    }

    tbody tr:hover {
      background: #f8fafc;
    }

    tbody td {
      padding: 18px 24px;
      font-size: 13px;
      color: var(--ink);
      vertical-align: middle;
    }

    /* Product ID pill */
    .id-pill {
      background: rgba(15, 92, 91, 0.06);
      color: var(--amber);
      font-size: 11px;
      font-weight: 600;
      padding: 4px 14px;
      border-radius: 100px;
      white-space: nowrap;
      letter-spacing: 0.02em;
      border: 1px solid rgba(15, 92, 91, 0.1);
    }

    /* Status badges */
    .badge-status {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 600;
      padding: 5px 14px;
      border-radius: 100px;
      white-space: nowrap;
    }

    .badge-status::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .badge-genuine {
      background: #ecfdf5;
      color: #047857;
      border: 1px solid #a7f3d0;
    }

    .badge-genuine::before {
      background: #10b981;
      box-shadow: 0 0 5px #10b981;
    }

    .badge-counterfeit {
      background: #fef2f2;
      color: #b91c1c;
      border: 1px solid #fecaca;
    }

    .badge-counterfeit::before {
      background: #ef4444;
      box-shadow: 0 0 5px #ef4444;
    }

    .badge-unknown {
      background: #f8fafc;
      color: #64748b;
      border: 1px solid #e2e8f0;
    }

    .badge-unknown::before {
      background: #94a3b8;
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
    }

    .empty-state svg {
      margin-bottom: 16px;
      stroke: var(--umber);
      margin-left: auto;
      margin-right: auto;
      display: block;
    }

    .empty-state p {
      font-size: 13px;
      color: var(--umber);
    }

    .table-footer {
      padding: 20px 32px;
      background: #f8fafc;
      border-top: 1.5px solid #e2e8f0;
    }

    .table-footer p {
      font-size: 11px;
      color: var(--umber);
      font-weight: 500;
    }

    /* ── FOOTER ── */
    .site-footer {
      text-align: center;
      padding: 24px;
      font-size: 11px;
      color: var(--umber);
      letter-spacing: 0.05em;
      border-top: 1px solid #f1f5f9;
      margin-top: auto;
    }

    .site-footer strong {
      color: var(--amber);
      font-weight: 600;
    }

    /* ── PAGINATION CONTROLS ── */
    .table-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }

    .pagination-controls {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn-page {
      padding: 6px 14px;
      background: transparent;
      border: 1.5px solid #e2e8f0;
      border-radius: 20px;
      font-family: 'Outfit', sans-serif;
      font-size: 11px;
      font-weight: 600;
      color: var(--ink);
      cursor: pointer;
      transition: all 0.2s ease;
      outline: none;
    }

    .btn-page:hover:not(:disabled) {
      border-color: var(--honey);
      color: var(--honey);
    }

    .btn-page:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    /* ── RESPONSIVENESS MEDIA QUERIES ── */
    @media (max-width: 768px) {
      .dashboard-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }
      .dashboard-header .btn-analytics {
        width: 100%;
        text-align: center;
        justify-content: center;
      }
      .table-card-header {
        padding: 20px;
        flex-direction: column;
        align-items: stretch;
        gap: 16px;
      }
      .header-actions {
        flex-direction: column;
        align-items: stretch;
        width: 100%;
        gap: 12px;
      }
      .search-wrap input {
        width: 100% !important;
      }
      .btn-export, .btn-analytics {
        width: 100%;
        justify-content: center;
      }
      .stats-row {
        grid-template-columns: 1fr;
      }
      .content {
        padding: 20px 16px !important;
      }
      tbody td, thead th {
        padding: 12px 16px;
      }
    }
  </style>
</head>

<body>

  <%- include('partials/sidebar', { active: 'scan-monitor' }) %>

  <!-- MAIN -->
  <div class="main">

    <%- include('partials/topbar', { pageTitle: 'Dashboard', pageSub: 'Real-time scan metrics overview' }) %>

    <!-- CONTENT -->
    <div class="content" style="padding: 36px 40px; overflow-y: auto; display: flex; flex-direction: column; gap: 24px;">

      <!-- PAGE TITLE HEADER -->
      <div class="dashboard-header">
        <div>
          <div class="page-tag">Scan activity</div>
          <div class="page-title">Metrics Dashboard</div>
        </div>
        <div style="display: flex; gap: 12px;">
          <a href="/admin/knowledge-base" class="btn-analytics" style="border-color: var(--amber); color: var(--amber);">Knowledge Base</a>
          <a href="/all-products" class="btn-analytics">All Products</a>
        </div>
      </div>

      <!-- STAT CARDS -->
      <div class="stats-row">
        <!-- Card 1: Total Scans -->
        <div class="stat-card" style="--kpi-color: var(--amber);">
          <div class="stat-num"><%= records.length %></div>
          <div class="stat-label">
            <span class="stat-dot"></span>Total Scans
          </div>
        </div>

        <!-- Card 2: Genuine -->
        <div class="stat-card" style="--kpi-color: #10b981; --kpi-text-color: #047857;">
          <div class="stat-num">
            <%= records.filter(r => r.productstatus === 'Genuine').length %>
          </div>
          <div class="stat-label">
            <span class="stat-dot"></span>Genuine Scans
          </div>
        </div>

        <!-- Card 3: Counterfeit -->
        <div class="stat-card" style="--kpi-color: #ef4444; --kpi-text-color: #b91c1c;">
          <div class="stat-num">
            <%= records.filter(r => r.productstatus === 'Counterfeit').length %>
          </div>
          <div class="stat-label">
            <span class="stat-dot"></span>Counterfeit Scans
          </div>
        </div>

        <!-- Card 4: Unknown -->
        <div class="stat-card" style="--kpi-color: var(--umber);">
          <div class="stat-num">
            <%= records.filter(r => r.productstatus !== 'Genuine' && r.productstatus !== 'Counterfeit').length %>
          </div>
          <div class="stat-label">
            <span class="stat-dot"></span>Unknown / Inactive
          </div>
        </div>
      </div>

      <!-- MAIN TABLE CARD -->
      <div class="table-card">
        <!-- Header -->
        <div class="table-card-header">
          <div>
            <h2>Scan Records</h2>
            <p>List of all product verification requests</p>
          </div>
          <div class="header-actions">
            <!-- Search -->
            <div class="search-wrap">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <circle cx="11" cy="11" r="8" stroke="var(--umber)" stroke-width="1.8" />
                <path d="M21 21l-4.35-4.35" stroke="var(--umber)" stroke-width="1.8" stroke-linecap="round" />
              </svg>
              <input type="text" id="searchInput" placeholder="Search scan records…" oninput="filterTable()">
            </div>
            <!-- Export -->
            <button class="btn-export" onclick="exportCSV()">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Export CSV
            </button>
            <a href="/analytics" class="btn-analytics">
              <span>View Analytics</span>
            </a>
          </div>
        </div>

        <!-- Table Wrap -->
        <div class="table-wrap">
          <table id="recordsTable">
            <thead>
              <tr>
                <th>Product ID</th>
                <th>Scan Date</th>
                <th>Location</th>
                <th>IP Address</th>
                <th>Device ID</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if(records.length === 0) { %>
                <tr class="empty-row-tr">
                  <td colspan="6">
                    <div class="empty-state">
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke="var(--umber)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      <p>No scan records found yet.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
              <% for(let record of records) { %>
                <tr>
                  <td><span class="id-pill"><%= record.productId && record.productId.name ? record.productId.name : (record.productId || 'Unknown') %></span></td>
                  <td style="color: var(--umber); font-weight: 500;"><%= new Date(record.scanDate).toLocaleString() %></td>
                  <td><%= record.location || 'Unknown' %></td>
                  <td style="font-family: monospace; font-size: 12px; color: var(--umber);"><%= record.ipAddress %></td>
                  <td style="font-family: monospace; font-size: 12px; color: var(--umber);"><%= record.deviceId ? record.deviceId.substring(0, 8) + '...' : 'Unknown' %></td>
                  <td>
                    <% if(record.productstatus === 'Genuine') { %>
                      <span class="badge-status badge-genuine">Genuine</span>
                    <% } else if(record.productstatus === 'Counterfeit') { %>
                      <span class="badge-status badge-counterfeit">Counterfeit</span>
                    <% } else { %>
                      <span class="badge-status badge-unknown"><%= record.productstatus %></span>
                    <% } %>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Footer -->
        <div class="table-footer">
          <p id="recordCount">Showing <%= records.length %> record<%= records.length !== 1 ? 's' : '' %></p>
          <% if (records.length > 0) { %>
            <div class="pagination-controls">
              <button id="prevPageBtn" class="btn-page" onclick="prevPage()">← Prev</button>
              <span id="pageIndicator" style="font-size: 12px; color: var(--umber); font-weight: 600;">Page 1 of 1</span>
              <button id="nextPageBtn" class="btn-page" onclick="nextPage()">Next →</button>
            </div>
          <% } %>
        </div>
      </div>

    </div>

    <!-- SITE FOOTER -->
    <div class="site-footer">
      © 2026 <strong>Trust layer</strong> · Admin Portal · All rights reserved
    </div>

  </div>

  <script>
    let currentPage = 1;
    const recordsPerPage = 10;
    let filteredRows = [];

    function initPagination() {
      const rows = Array.from(document.querySelectorAll('#recordsTable tbody tr:not(.empty-row-tr)'));
      filteredRows = rows;
      showPage(1);
    }

    function showPage(page) {
      currentPage = page;
      const totalPages = Math.ceil(filteredRows.length / recordsPerPage);
      
      // Hide all rows in tbody first
      const allRows = document.querySelectorAll('#recordsTable tbody tr:not(.empty-row-tr)');
      allRows.forEach(row => row.style.display = 'none');
      
      const start = (page - 1) * recordsPerPage;
      const end = start + recordsPerPage;
      
      const visibleRows = filteredRows.slice(start, end);
      visibleRows.forEach(row => row.style.display = '');

      const pageIndicator = document.getElementById('pageIndicator');
      if (pageIndicator) {
        pageIndicator.textContent = `Page ${page} of ${totalPages || 1}`;
      }
      
      const prevBtn = document.getElementById('prevPageBtn');
      const nextBtn = document.getElementById('nextPageBtn');
      if (prevBtn) prevBtn.disabled = (page === 1);
      if (nextBtn) nextBtn.disabled = (page >= totalPages || totalPages === 0);

      const startCount = filteredRows.length === 0 ? 0 : start + 1;
      const endCount = Math.min(end, filteredRows.length);
      document.getElementById('recordCount').textContent = 
        `Showing ${startCount}-${endCount} of ${filteredRows.length} record${filteredRows.length !== 1 ? 's' : ''}`;
    }

    function nextPage() {
      const totalPages = Math.ceil(filteredRows.length / recordsPerPage);
      if (currentPage < totalPages) {
        showPage(currentPage + 1);
      }
    }

    function prevPage() {
      if (currentPage > 1) {
        showPage(currentPage - 1);
      }
    }

    // Live search filter
    function filterTable() {
      const query = document.getElementById('searchInput').value.toLowerCase();
      const allRows = Array.from(document.querySelectorAll('#recordsTable tbody tr:not(.empty-row-tr)'));
      
      filteredRows = allRows.filter(row => {
        const text = row.textContent.toLowerCase();
        return text.includes(query);
      });

      showPage(1);
    }

    // CSV export
    function exportCSV() {
      const rows = document.querySelectorAll('#recordsTable tr');
      const csv = Array.from(rows).map(row =>
        Array.from(row.querySelectorAll('th, td'))
          .map(cell => `"${cell.textContent.trim()}"`)
          .join(',')
      ).join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'scan-records.csv';
      a.click();
    }

    // Initialize on DOM load
    window.addEventListener('DOMContentLoaded', () => {
      initPagination();
    });
  </script>

</body>

</html>