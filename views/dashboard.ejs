<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Trust Layer</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #0a0f0a; color: #e8f5e8; min-height: 100vh; }

    /* NAV */
    .nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 40px; height: 64px;
      background: #060c06; border-bottom: 1px solid #1a3a1a;
      position: sticky; top: 0; z-index: 100;
    }
    .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .nav-icon {
      width: 32px; height: 32px; background: #1a4d1a;
      border: 1px solid #2d7a2d; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .nav-name { font-size: 15px; font-weight: 500; color: #a8e6a8; letter-spacing: 0.03em; }
    .nav-sep { font-size: 11px; color: #1a4d1a; margin: 0 4px; }
    .nav-sub { font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: #3a6b3a; }
    .nav-links { display: flex; align-items: center; gap: 8px; }
    .nav-link {
      font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
      color: #3a6b3a; text-decoration: none; padding: 7px 14px;
      border-radius: 6px; transition: all 0.2s;
    }
    .nav-link:hover { color: #a8e6a8; background: #0d1a0d; }
    .nav-badge {
      background: #0d2a0d; border: 1px solid #2d7a2d; color: #4caf50;
      font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
      padding: 5px 14px; border-radius: 100px;
    }

    /* PAGE HEADER */
    .page-header {
      background: #060c06; border-bottom: 1px solid #1a3a1a;
      padding: 40px 40px 100px;
    }
    .page-header-inner { max-width: 1200px; margin: 0 auto; }
    .page-tag {
      font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase;
      color: #2d7a2d; margin-bottom: 10px;
      display: flex; align-items: center; gap: 8px;
    }
    .page-tag::after { content: ''; flex: 0 0 32px; height: 1px; background: #1a3a1a; }
    .page-header h1 { font-size: 26px; font-weight: 500; color: #e8f5e8; margin-bottom: 4px; letter-spacing: -0.02em; }
    .page-header p { font-size: 13px; color: #3a6b3a; line-height: 1.6; }

    /* STAT CARDS */
    .stats-row {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 14px; margin-top: 32px;
    }
    .stat-card {
      background: #0d1a0d; border: 1px solid #1a3a1a; border-radius: 10px;
      padding: 20px 22px;
    }
    .stat-num { font-size: 28px; font-weight: 500; color: #e8f5e8; line-height: 1; margin-bottom: 6px; letter-spacing: -0.02em; }
    .stat-label {
      font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
      color: #3a6b3a; display: flex; align-items: center; gap: 6px;
    }
    .stat-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    /* MAIN CONTENT */
    .main-content {
      max-width: 1200px; margin: -52px auto 60px;
      padding: 0 40px; position: relative; z-index: 1;
    }

    /* TABLE CARD */
    .table-card {
      background: #0d1a0d; border: 1px solid #1a3a1a; border-radius: 12px;
      overflow: hidden;
      animation: riseUp 0.5s cubic-bezier(0.22,1,0.36,1) 0.1s both;
    }
    @keyframes riseUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .table-card-header {
      padding: 22px 28px; border-bottom: 1px solid #1a3a1a;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 12px;
    }
    .table-card-header h2 { font-size: 15px; font-weight: 500; color: #e8f5e8; margin-bottom: 2px; }
    .table-card-header p { font-size: 11px; color: #3a6b3a; }

    /* SEARCH */
    .search-wrap { position: relative; }
    .search-wrap input {
      padding: 9px 14px 9px 36px;
      background: #111811; border: 1px solid #1a3a1a; border-radius: 7px;
      font-size: 12px; color: #e8f5e8; font-family: inherit;
      width: 220px; outline: none; transition: border-color 0.2s;
    }
    .search-wrap input::placeholder { color: #2d4d2d; }
    .search-wrap input:focus { border-color: #2d7a2d; }
    .search-wrap svg { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); pointer-events: none; }

    /* TABLE */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #111811; border-bottom: 1px solid #b2b9b2; }
    thead th {
      padding: 13px 20px; font-size: 9px; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase; color: #2d7a2d;
      white-space: nowrap; text-align: left;
    }
    tbody tr { border-bottom: 1px solid #111811; transition: background 0.15s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #0f1f0f; }
    tbody td { padding: 14px 20px; font-size: 13px; color: #a8e6a8; vertical-align: middle; }

    /* ID PILL */
    .id-pill {
      background: #0d2a0d; border: 1px solid #1a4d1a; color: #4caf50;
      font-size: 10px; font-weight: 500; padding: 4px 10px;
      border-radius: 100px; white-space: nowrap;
      letter-spacing: 0.06em; font-family: monospace;
    }

    /* BADGES */
    .badge-status {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 500;
      padding: 5px 12px; border-radius: 100px; white-space: nowrap;
      letter-spacing: 0.05em;
    }
    .badge-status::before {
      content: ''; width: 5px; height: 5px;
      border-radius: 50%; flex-shrink: 0;
    }
    .badge-genuine {
      background: #0d2a0d; border: 1px solid #2d7a2d; color: #4caf50;
    }
    .badge-genuine::before { background: #4caf50; }
    .badge-counterfeit {
      background: #1a0d0d; border: 1px solid #5a1a1a; color: #e05a5a;
    }
    .badge-counterfeit::before { background: #e05a5a; }
    .badge-unknown {
      background: #1a1a0d; border: 1px solid #4d4d1a; color: #d4a017;
    }
    .badge-unknown::before { background: #d4a017; }

    .meta-text { font-size: 12px; color: #cfe4cf; }

    /* EMPTY STATE */
    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-icon {
      width: 56px; height: 56px; background: #111811;
      border: 1px solid #1a3a1a; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 14px;
    }
    .empty-state p { font-size: 13px; color: #3a6b3a; }

    /* TABLE FOOTER */
    .table-footer {
      padding: 16px 28px; border-top: 1px solid #1a3a1a;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 10px;
    }
    .table-footer p { font-size: 12px; color: #3a6b3a; }

    .btn-export {
      background: #2d7a2d; color: #e8f5e8;
      font-size: 11px; font-weight: 500; font-family: inherit;
      padding: 8px 18px; border: none; border-radius: 6px;
      cursor: pointer; letter-spacing: 0.1em; text-transform: uppercase;
      display: inline-flex; align-items: center; gap: 7px;
      transition: background 0.2s;
    }
    .btn-export:hover { background: #3a9e3a; }

    .btn-analytics {
      background: transparent; color: #4caf50;
      font-size: 11px; font-weight: 500; font-family: inherit;
      padding: 8px 18px; border: 1px solid #2d7a2d; border-radius: 6px;
      cursor: pointer; letter-spacing: 0.1em; text-transform: uppercase;
      display: inline-flex; align-items: center; gap: 7px;
      transition: all 0.2s;
    }
    .btn-analytics:hover { background: #0d2a0d; }

    /* FOOTER */
    .site-footer {
      background: #060c06; border-top: 1px solid #1a3a1a;
      text-align: center; padding: 22px;
      font-size: 11px; color: #3a6b3a; letter-spacing: 0.08em;
      margin-top: 40px;
    }
    .site-footer strong { color: #4caf50; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .stats-row { grid-template-columns: repeat(2, 1fr); }
      .page-header { padding: 32px 20px 90px; }
      .main-content { padding: 0 16px; }
      .nav { padding: 0 20px; }
    }
    @media (max-width: 560px) {
      .stats-row { grid-template-columns: 1fr 1fr; }
      .table-card-header { flex-direction: column; align-items: flex-start; }
      .search-wrap input { width: 100%; }
      .search-wrap { width: 100%; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <a class="nav-brand" href="/">
    <div class="nav-icon">
      <svg width="17" height="17" viewBox="0 0 18 18" fill="none">
        <path d="M9 2L3 6v4c0 3.3 2.5 6.4 6 7.2C12.5 16.4 15 13.3 15 10V6L9 2z" fill="#4caf50" opacity="0.9"/>
        <path d="M7 9.5l1.5 1.5 3-3" stroke="#0d1a0d" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <span class="nav-name">Trust Layer</span>
    <span class="nav-sep">·</span>
    <span class="nav-sub">Admin Portal</span>
  </a>
  <div class="nav-links">
    <a class="nav-link" href="/">← Home</a>
    <a class="nav-link" href="/all-products">All Products</a>
    <a class="nav-link" href="/add-product">Add Product</a>
    <span class="nav-badge">Admin</span>
  </div>
</nav>

<!-- PAGE HEADER -->
<div class="page-header">
  <div class="page-header-inner">
    <div class="page-tag">Admin dashboard</div>
    <h1>Scan records</h1>
    <p>Monitor all product verification events and authentication records in real time.</p>

    <div class="stats-row">

      <div class="stat-card">
        <div class="stat-num"><%= records.length %></div>
        <div class="stat-label">
          <span class="stat-dot" style="background:#5a8c5a"></span>
          Total scans
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-num" style="color:#4caf50;">
          <%= records.filter(r => r.productstatus === 'Genuine').length %>
        </div>
        <div class="stat-label">
          <span class="stat-dot" style="background:#4caf50"></span>
          Genuine
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-num" style="color:#e05a5a;">
          <%= records.filter(r => r.productstatus === 'Counterfeit').length %>
        </div>
        <div class="stat-label">
          <span class="stat-dot" style="background:#e05a5a"></span>
          Counterfeit
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-num" style="color:#d4a017;">
          <%= records.filter(r => r.productstatus !== 'Genuine' && r.productstatus !== 'Counterfeit').length %>
        </div>
        <div class="stat-label">
          <span class="stat-dot" style="background:#d4a017"></span>
          Unknown
        </div>
      </div>

    </div>
  </div>
</div>

<!-- MAIN CONTENT -->
<div class="main-content">
  <div class="table-card">

    <div class="table-card-header">
      <div>
        <h2>All scan records</h2>
        <p>Every product verification event logged by the system</p>
      </div>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <div class="search-wrap">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
            <circle cx="7" cy="7" r="4.5" stroke="#3a6b3a" stroke-width="1.2"/>
            <path d="M10.5 10.5L14 14" stroke="#3a6b3a" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <input type="text" id="searchInput" placeholder="Search records…" oninput="filterTable()">
        </div>
        <button class="btn-analytics" onclick="exportCSV()">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
            <path d="M2 11l3-3 2.5 2.5 3.5-5L14 11" stroke="#4caf50" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Analytics
        </button>
      </div>
    </div>

    <!-- TABLE -->
    <div class="table-wrap">
      <table id="recordsTable">
        <thead>
          <tr>
            <th>Product ID</th>
            <th>Scan date</th>
            <th>Location</th>
            <th>IP address</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>

          <% if(records.length === 0) { %>
          <tr>
            <td colspan="5">
              <div class="empty-state">
                <div class="empty-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke="#1a4d1a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <p>No scan records found yet.</p>
              </div>
            </td>
          </tr>
          <% } %>

          <% for(let record of records) { %>
          <tr>
            <td><span class="id-pill"><%= record.productId %></span></td>
            <td class="meta-text"><%= record.scanDate %></td>
            <td class="meta-text"><%= record.location %></td>
            <td class="meta-text"><%= record.ipAddress %></td>
            <td>
              <% if(record.productstatus === 'Genuine') { %>
                <span class="badge-status badge-genuine">Genuine</span>
              <% } else if(record.productstatus === 'Counterfeit') { %>
                <span class="badge-status badge-counterfeit">Counterfeit</span>
              <% } else { %>
                <span class="badge-status badge-unknown"><%= record.productstatus %></span>
              <% } %>
            </td>
          </tr>
          <% } %>

        </tbody>
      </table>
    </div>

    <!-- CARD FOOTER -->
    <div class="table-footer">
      <p id="recordCount">Showing <%= records.length %> record<%= records.length !== 1 ? 's' : '' %></p>
      <button class="btn-export" onclick="downloadCSV()">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
          <path d="M8 2v9M5 8l3 3 3-3" stroke="#e8f5e8" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 13h12" stroke="#e8f5e8" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        Export CSV
      </button>
    </div>

  </div>
</div>

<!-- FOOTER -->
<footer class="site-footer">
  © 2026 <strong>Trust Layer</strong> · Admin Portal · All rights reserved
</footer>

<script>
function filterTable() {
  const query = document.getElementById('searchInput').value.toLowerCase();
  const rows = document.querySelectorAll('#recordsTable tbody tr');
  let visible = 0;
  rows.forEach(row => {
    const text = row.textContent.toLowerCase();
    const show = text.includes(query);
    row.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  document.getElementById('recordCount').textContent =
    'Showing ' + visible + ' record' + (visible !== 1 ? 's' : '');
}

function downloadCSV() {
  const rows = document.querySelectorAll('#recordsTable tr');
  const csv = Array.from(rows).map(row =>
    Array.from(row.querySelectorAll('th, td'))
      .map(cell => '"' + cell.textContent.trim() + '"')
      .join(',')
  ).join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'trust-layer-scan-records.csv';
  a.click();
}

function exportCSV() {
  const rows = document.querySelectorAll('#recordsTable tr');
  const csv = Array.from(rows).map(row =>
    Array.from(row.querySelectorAll('th, td'))
      .map(cell => '"' + cell.textContent.trim() + '"')
      .join(',')
  ).join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const file = new File([blob], 'trust-layer-scan-records.csv');
  const formData = new FormData();
  formData.append('file', file);
  fetch('http://localhost:5000/analyze', {
    method: 'POST',
    body: formData
  })
  .then(response => response.blob())
  .then(blob => {
    const url = window.URL.createObjectURL(blob);
    window.open(url);
  })
  .catch(error => console.error('Error:', error));
}
</script>

</body>
</html>
